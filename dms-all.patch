+    # Use a long prompt (~60% of context) + enough decode tokens to
+    # push total past window_size (512) by a large margin.
+    prompt_target = int(max_model_len * 0.5)
+    decode_tokens = min(max_model_len - prompt_target - 64, 2048)
+    prompt = _build_long_prompt(prompt_target)
