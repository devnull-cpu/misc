+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Benchmark prefix caching with DMS: measures TTFT improvement.
+
+Sends multiple requests with a shared prefix. The first request computes
+the prefix from scratch; subsequent requests should hit prefix cache
+(with CoW for DMS), giving faster TTFT.
+
+Usage:
+    python tests/v1/attention/bench_prefix_cache.py
+"""
+
+import os
+import time
+
+os.environ["VLLM_ENABLE_V1_MULTIPROCESSING"] = "0"
+
+from vllm import LLM, SamplingParams
+
+MODEL_PATH = os.path.normpath(os.path.join(
+    os.path.dirname(os.path.abspath(__file__)),
+    "..", "..", "..", "models", "Qwen3-8B-DMS-8x-4bit-NF4",
+))
+
+# Shared system prompt (~200 tokens).
+SHARED_PREFIX = (
+    "You are an expert AI assistant specializing in science and technology. "
+    "You provide detailed, accurate, and well-structured answers. "
+    "When answering questions, consider multiple perspectives and cite "
+    "relevant research where applicable. Always be concise but thorough. "
+    "If you are unsure about something, say so rather than guessing. "
+    "Format your answers with clear headings and bullet points when "
+    "appropriate. Avoid unnecessary repetition and filler words. "
+    "Here is some additional context for your knowledge base: "
+    "The laws of thermodynamics govern energy transfer in all physical "
+    "systems. Conservation of energy states that energy cannot be created "
+    "or destroyed, only transformed. Entropy in a closed system tends to "
+    "increase over time. "
+)
+
+QUESTIONS = [
+    "What is quantum entanglement?",
+    "Explain the theory of relativity.",
+    "How does photosynthesis work?",
+    "What causes tides on Earth?",
+    "Describe the structure of DNA.",
+    "What is dark matter?",
+    "How do neural networks learn?",
+    "Explain the greenhouse effect.",
+]
+
+
+def bench_prefix_cache():
+    print(f"Model: {MODEL_PATH}")
+    print(f"Shared prefix length: ~{len(SHARED_PREFIX.split())} words")
+    print(f"Number of requests: {len(QUESTIONS)}")
+
+    llm = LLM(
+        model=MODEL_PATH,
+        quantization="bitsandbytes",
+        load_format="bitsandbytes",
+        dtype="bfloat16",
+        max_model_len=2048,
+        gpu_memory_utilization=0.7,
+        enforce_eager=True,
+    )
+
+    params = SamplingParams(max_tokens=64, temperature=0.0)
+
+    # Warm up.
+    llm.generate(["Hello"], params)
+
+    # Sequential requests to measure individual TTFT.
+    ttfts = []
+    for i, question in enumerate(QUESTIONS):
+        prompt = SHARED_PREFIX + question
+        t0 = time.perf_counter()
+        out = llm.generate([prompt], params)
+        t1 = time.perf_counter()
+        tokens_out = len(out[0].outputs[0].token_ids)
+        tokens_in = len(out[0].prompt_token_ids)
+        elapsed = t1 - t0
+        ttfts.append(elapsed)
+        tag = "COLD" if i == 0 else "WARM"
+        print(f"  [{tag}] Request {i}: {elapsed:.3f}s "
+              f"(in={tokens_in}, out={tokens_out})")
+
+    cold_ttft = ttfts[0]
+    warm_ttfts = ttfts[1:]
+    avg_warm = sum(warm_ttfts) / len(warm_ttfts) if warm_ttfts else 0
+
+    print(f"\nResults:")
+    print(f"  Cold TTFT (no prefix cache): {cold_ttft:.3f}s")
+    print(f"  Avg warm TTFT (prefix cached): {avg_warm:.3f}s")
+    if cold_ttft > 0:
+        speedup = cold_ttft / avg_warm if avg_warm > 0 else float("inf")
+        print(f"  Speedup: {speedup:.2f}x")
+
+    # Batch all at once to measure throughput.
+    prompts = [SHARED_PREFIX + q for q in QUESTIONS]
+    t0 = time.perf_counter()
+    outputs = llm.generate(prompts, params)
+    t1 = time.perf_counter()
+    total_out = sum(len(o.outputs[0].token_ids) for o in outputs)
+    total_in = sum(len(o.prompt_token_ids) for o in outputs)
+    elapsed = t1 - t0
+    print(f"\n  Batch ({len(QUESTIONS)} requests): {elapsed:.3f}s")
+    print(f"  Total input tokens: {total_in}")
+    print(f"  Total output tokens: {total_out}")
+    print(f"  Output throughput: {total_out / elapsed:.1f} tok/s")
+
+
+if __name__ == "__main__":
+    bench_prefix_cache()
