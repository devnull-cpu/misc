+class TestCacheUpdatePadding:
+    """Test that the fused cache update kernel handles padded batches."""
+
+    def test_padding_skips_cache_write(self, device):
+        """Padding requests (block_id=-1) shouldn't write to cache."""
+        from vllm.config.dms import DMSConfig
+        from vllm.v1.attention.dms.dms_state import DMSState
+        from vllm.v1.attention.dms.triton_dms_cache_update import (
+            dms_fused_cache_update,
+        )
+
+        num_kv_heads = 4
+        head_dim = 128
+        block_size = 16
+        num_blocks = 20
+        num_reqs = 4  # 2 real + 2 padding
+
+        dms_config = DMSConfig(
+            dms_window_size=8,
+            dms_compression_ratio=8,
+        )
+        dms_state = DMSState(
+            dms_config=dms_config,
+            batch_size=num_reqs,
+            num_kv_heads=num_kv_heads,
+            max_seq_len=256,
+            block_size=block_size,
+            device=device,
+        )
+
+        # Initialize first 2 requests with valid state
+        for r in range(2):
+            start = r * num_kv_heads
+            end = start + num_kv_heads
+            dms_state.cache_seq_lens[start:end] = 32
+            dms_state.tokens_seen[start:end] = 32
+
+        # K/V to write
+        key = torch.randn(num_reqs, num_kv_heads, head_dim,
+                           dtype=torch.bfloat16, device=device)
+        value = torch.randn_like(key)
+
+        # KV cache
+        kc = torch.zeros(num_blocks, block_size, num_kv_heads, head_dim,
+                          dtype=torch.bfloat16, device=device)
+        vc = torch.zeros_like(kc)
+
+        # Save cache state before update
+        kc_before = kc.clone()
+
+        # Block table: real requests get valid blocks, padding gets -1
+        bt = torch.full((num_reqs, 10), -1, dtype=torch.int32, device=device)
+        bt[0, :3] = torch.tensor([0, 1, 2], dtype=torch.int32, device=device)
+        bt[1, :3] = torch.tensor([3, 4, 5], dtype=torch.int32, device=device)
+        # bt[2:] stays -1 (padding)
+
+        decisions = torch.zeros(num_reqs, num_kv_heads, dtype=torch.float32,
+                                 device=device)
+
+        dms_fused_cache_update(
+            key, value, kc, vc, bt, decisions, dms_state, num_reqs,
+        )
+
+        # Blocks belonging to real requests (0-5) may have been written to
+        # Blocks NOT belonging to any request should be untouched
+        assert torch.allclose(kc[6:], kc_before[6:]), \
+            "Blocks not assigned to any request should be untouched"
+
+        # Padding DMSState entries should NOT have incremented
+        # (the kernel returned early for them)
+        for r in range(2, 4):
+            start = r * num_kv_heads
+            end = start + num_kv_heads
+            assert (dms_state.cache_seq_lens[start:end] == 0).all(), \
+                f"Padding request {r} cache_seq_lens should remain 0"
+            assert (dms_state.tokens_seen[start:end] == 0).all(), \
+                f"Padding request {r} tokens_seen should remain 0"
+
+    def test_multiple_steps_no_corruption(self, device):
+        """Multiple decode steps with padding shouldn't corrupt real data."""
+        from vllm.config.dms import DMSConfig
+        from vllm.v1.attention.dms.dms_state import DMSState
+        from vllm.v1.attention.dms.triton_dms_cache_update import (
+            dms_fused_cache_update,
+        )
+
+        num_kv_heads = 4
+        head_dim = 128
+        block_size = 16
+        num_blocks = 20
+        num_reqs = 4  # 2 real + 2 padding
+
+        dms_config = DMSConfig(
+            dms_window_size=8,
+            dms_compression_ratio=8,
+        )
+        dms_state = DMSState(
+            dms_config=dms_config,
+            batch_size=num_reqs,
+            num_kv_heads=num_kv_heads,
+            max_seq_len=256,
+            block_size=block_size,
+            device=device,
+        )
+
+        # Initialize first 2 requests
+        for r in range(2):
+            start = r * num_kv_heads
+            end = start + num_kv_heads
+            dms_state.cache_seq_lens[start:end] = 10
+            dms_state.tokens_seen[start:end] = 10
+
+        kc = torch.zeros(num_blocks, block_size, num_kv_heads, head_dim,
+                          dtype=torch.bfloat16, device=device)
+        vc = torch.zeros_like(kc)
+
+        bt = torch.full((num_reqs, 10), -1, dtype=torch.int32, device=device)
+        bt[0, :3] = torch.tensor([0, 1, 2], dtype=torch.int32, device=device)
+        bt[1, :3] = torch.tensor([3, 4, 5], dtype=torch.int32, device=device)
+
+        decisions = torch.zeros(num_reqs, num_kv_heads, dtype=torch.float32,
+                                 device=device)
+
+        # Simulate 20 decode steps (like CUDAGraph replay)
+        for step in range(20):
+            key = torch.randn(num_reqs, num_kv_heads, head_dim,
+                               dtype=torch.bfloat16, device=device)
+            value = torch.randn_like(key)
+            dms_fused_cache_update(
+                key, value, kc, vc, bt, decisions, dms_state, num_reqs,
+            )
+
+        # Real requests should have grown
+        for r in range(2):
+            start = r * num_kv_heads
+            end = start + num_kv_heads
+            assert (dms_state.cache_seq_lens[start:end] == 30).all(), \
+                f"Real request {r} should have seq_len = 10 + 20 = 30"
+
+        # Padding requests should still be at 0
+        for r in range(2, 4):
+            start = r * num_kv_heads
+            end = start + num_kv_heads
+            assert (dms_state.cache_seq_lens[start:end] == 0).all(), \
+                f"Padding request {r} should still have seq_len = 0"
+
