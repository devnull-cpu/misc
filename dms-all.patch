+    def _forward_decode_per_head(
+        self,
+        query: torch.Tensor,
+        key_cache: torch.Tensor,
+        value_cache: torch.Tensor,
+        output: torch.Tensor,
+        per_head_seq_lens: torch.Tensor,
+        per_head_block_table: torch.Tensor,
+        layer: torch.nn.Module,
+    ) -> torch.Tensor:
+        """Decode with per-head seq_lens by iterating over KV heads.
+
+        vLLM's KV cache stores all heads in shared blocks:
+        cache[block_id, offset, head, :]. flash_attn_varlen_func reads
+        all heads from each block, so we can't use the batch×head
+        flattening trick directly. Instead, we call flash_attn once
+        per KV head with a single-head cache view and that head's
+        seq_lens.
+
+        This is num_kv_heads calls per layer (8 for Qwen3-8B).
+        A custom kernel could fuse this in Phase 3.
+        """
+        batch_size = query.shape[0]
+        q_per_kv = self.num_queries_per_kv
+        block_table = per_head_block_table[:batch_size]  # (num_reqs, max_blocks)
+
+        # Q: (batch, num_q_heads, head_dim) → (batch, num_kv_heads, q_per_kv, head_dim)
+        q_by_kv_head = query.view(
+            batch_size, self.num_kv_heads, q_per_kv, self.head_size
+        )
+
+        # cu_seqlens_q for a batch of single-token decode requests,
+        # each with q_per_kv query heads.
+        cu_seqlens_q = torch.arange(
+            0,
+            (batch_size + 1) * q_per_kv,
+            q_per_kv,
+            dtype=torch.int32,
+            device=query.device,
+        )
+
+        descale_shape = (batch_size, 1)
+        q_descale = layer._q_scale.expand(descale_shape)
+        k_descale = layer._k_scale.expand(descale_shape)
+        v_descale = layer._v_scale.expand(descale_shape)
+
+        # Output buffer: (batch, num_kv_heads, q_per_kv, head_dim)
+        out_by_head = torch.empty(
+            batch_size, self.num_kv_heads, q_per_kv, self.head_size,
+            dtype=query.dtype,
+            device=query.device,
+        )
+
+        for h in range(self.num_kv_heads):
+            # Per-head seq_lens: extract every num_kv_heads-th entry.
+            head_seq_lens = per_head_seq_lens[h::self.num_kv_heads][:batch_size]
+            max_seq_len_k = int(head_seq_lens.max().item()) if batch_size > 0 else 0
+
+            if max_seq_len_k == 0:
+                out_by_head[:, h].zero_()
+                continue
+
+            # Extract single-head KV cache views.
+            # key_cache: (num_blocks, block_size, num_kv_heads, head_size)
+            # → select head h → (num_blocks, block_size, head_size)
+            # → unsqueeze to (num_blocks, block_size, 1, head_size)
+            k_head = key_cache[:, :, h:h+1, :].contiguous()
+            v_head = value_cache[:, :, h:h+1, :].contiguous()
+
+            # Q for this KV head group: (batch, q_per_kv, head_size)
+            q_head = q_by_kv_head[:, h, :, :]  # (batch, q_per_kv, head_size)
+            # Flatten to (batch * q_per_kv, 1, head_size) for flash_attn.
+            q_flat = q_head.reshape(batch_size * q_per_kv, 1, self.head_size)
+
+            out_head = torch.empty(
+                batch_size * q_per_kv, 1, self.head_size,
+                dtype=query.dtype,
+                device=query.device,
+            )
+
+            flash_attn_varlen_func(
+                q=q_flat,
+                k=k_head,
+                v=v_head,
+                out=out_head,
+                cu_seqlens_q=cu_seqlens_q,
+                max_seqlen_q=q_per_kv,
+                seqused_k=head_seq_lens,
+                max_seqlen_k=max_seq_len_k,
+                softmax_scale=self.scale,
+                causal=True,
+                alibi_slopes=self.alibi_slopes,
+                window_size=list(self.sliding_window),
+                block_table=block_table,
+                softcap=self.logits_soft_cap,
+                fa_version=self.vllm_flash_attn_version,
+                q_descale=q_descale,
+                k_descale=k_descale,
+                v_descale=v_descale,
+            )
+
+            # Store: (batch * q_per_kv, 1, head_size) → (batch, q_per_kv, head_size)
+            out_by_head[:, h] = out_head.squeeze(1).view(
+                batch_size, q_per_kv, self.head_size
             )
+
+        # Reshape: (batch, num_kv_heads, q_per_kv, head_dim) → (batch, num_q_heads, head_dim)
+        output[:batch_size] = out_by_head.reshape(
+            batch_size, self.num_heads, self.head_size
+        )
+        return output
+
+    def do_kv_cache_update(
+        self,
+        layer: torch.nn.Module,
+        key: torch.Tensor,
+        value: torch.Tensor,
+        kv_cache: torch.Tensor,
+        slot_mapping: torch.Tensor,
