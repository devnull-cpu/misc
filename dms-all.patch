+# ---------------------------------------------------------------------------
+# Single-pass prefill: write_survivors_to_cache
+# ---------------------------------------------------------------------------
+
+
+def make_raw_kv(
+    seq_len: int,
+    num_kv_heads: int = 4,
+    head_size: int = 8,
+) -> tuple[torch.Tensor, torch.Tensor]:
+    """Create raw K/V tensors with identifiable values.
+
+    key[t, h, :] = t * 100 + h (broadcast), value same.
+    """
+    key = torch.zeros(seq_len, num_kv_heads, head_size)
+    value = torch.zeros(seq_len, num_kv_heads, head_size)
+    for t in range(seq_len):
+        for h in range(num_kv_heads):
+            val = float(t * 100 + h)
+            key[t, h, :] = val
+            value[t, h, :] = val
+    return key, value
+
+
+class TestWriteSurvivorsToCache:
+    def test_all_survive_writes_all(self):
+        """When all tokens survive, cache contains all tokens contiguously."""
+        num_kv_heads = 2
+        seq_len = 4
+        block_size = 16
+        head_size = 8
+
+        key, value = make_raw_kv(seq_len, num_kv_heads, head_size)
+        cache = torch.zeros(2, 1, block_size, num_kv_heads, head_size)
+        survivors = torch.ones(seq_len, num_kv_heads, dtype=torch.bool)
+        block_table = torch.tensor([0])
+
+        counts = write_survivors_to_cache(
+            key, value, cache, survivors, block_table, block_size,
+        )
+
+        assert (counts == seq_len).all()
+        # Verify all tokens written in order.
+        for t in range(seq_len):
+            for h in range(num_kv_heads):
+                expected = float(t * 100 + h)
+                assert cache[0, 0, t, h, 0].item() == expected
+                assert cache[1, 0, t, h, 0].item() == expected
+
+    def test_eviction_writes_only_survivors(self):
+        """Evicted tokens are skipped, survivors are contiguous."""
+        num_kv_heads = 2
+        seq_len = 4
+        block_size = 16
+        head_size = 8
+
+        key, value = make_raw_kv(seq_len, num_kv_heads, head_size)
+        cache = torch.zeros(2, 1, block_size, num_kv_heads, head_size)
+        block_table = torch.tensor([0])
+
+        # Head 0: evict token 1 (keep 0, 2, 3).
+        # Head 1: keep all.
+        survivors = torch.ones(seq_len, num_kv_heads, dtype=torch.bool)
+        survivors[1, 0] = False
+
+        counts = write_survivors_to_cache(
+            key, value, cache, survivors, block_table, block_size,
+        )
+
+        assert counts[0] == 3
+        assert counts[1] == 4
+
+        # Head 0: cache[0] = token 0, cache[1] = token 2, cache[2] = token 3.
+        assert cache[0, 0, 0, 0, 0].item() == 0.0    # token 0, head 0
+        assert cache[0, 0, 1, 0, 0].item() == 200.0  # token 2, head 0
+        assert cache[0, 0, 2, 0, 0].item() == 300.0  # token 3, head 0
+
+        # Head 1: all 4 tokens written.
+        for t in range(seq_len):
+            assert cache[0, 0, t, 1, 0].item() == float(t * 100 + 1)
+
+    def test_matches_compact_kv_cache(self):
+        """Single-pass write produces same cache state as write-all + compact."""
+        num_kv_heads = 2
+        seq_len = 8
+        block_size = 4
+        head_size = 4
+
+        key, value = make_raw_kv(seq_len, num_kv_heads, head_size)
+        block_table = torch.tensor([0, 1])
+
+        # Create survivor pattern: evict tokens 1, 3, 5 on head 0.
+        survivors = torch.ones(seq_len, num_kv_heads, dtype=torch.bool)
+        survivors[1, 0] = False
+        survivors[3, 0] = False
+        survivors[5, 0] = False
+
+        # Method 1: write_survivors_to_cache (single-pass).
+        cache_sp = torch.zeros(2, 2, block_size, num_kv_heads, head_size)
+        counts_sp = write_survivors_to_cache(
+            key, value, cache_sp, survivors, block_table, block_size,
+        )
+
+        # Method 2: write all + compact_kv_cache (two-pass).
+        cache_tp = torch.zeros(2, 2, block_size, num_kv_heads, head_size)
+        # Write all tokens to cache first.
+        for t in range(seq_len):
+            block_id = block_table[t // block_size]
+            offset = t % block_size
+            cache_tp[0, block_id, offset, :, :] = key[t]
+            cache_tp[1, block_id, offset, :, :] = value[t]
+        counts_tp, _ = compact_kv_cache(
+            cache_tp, survivors, seq_len, block_size, block_table,
+        )
+
+        # Both methods should produce identical per-head seq_lens.
+        assert torch.equal(counts_sp, counts_tp)
+
+        # Both methods should produce identical cache content for surviving
+        # positions (0..count-1 per head).
+        for h in range(num_kv_heads):
+            n = counts_sp[h].item()
+            for pos in range(n):
+                bid = block_table[pos // block_size].item()
+                off = pos % block_size
+                assert torch.equal(
+                    cache_sp[0, bid, off, h, :],
+                    cache_tp[0, bid, off, h, :],
+                ), f"Key mismatch at head {h}, pos {pos}"
+                assert torch.equal(
+                    cache_sp[1, bid, off, h, :],
+                    cache_tp[1, bid, off, h, :],
+                ), f"Value mismatch at head {h}, pos {pos}"
+
+    def test_cross_block_writes(self):
+        """Survivors spanning multiple blocks are written correctly."""
+        num_kv_heads = 1
+        seq_len = 6
+        block_size = 2
+        head_size = 4
+
+        key, value = make_raw_kv(seq_len, num_kv_heads, head_size)
+        cache = torch.zeros(2, 3, block_size, num_kv_heads, head_size)
+        block_table = torch.tensor([0, 1, 2])
+
+        # Keep tokens 0, 2, 4 (3 survivors spanning all blocks).
+        survivors = torch.zeros(seq_len, num_kv_heads, dtype=torch.bool)
+        survivors[0, 0] = True
+        survivors[2, 0] = True
+        survivors[4, 0] = True
+
+        counts = write_survivors_to_cache(
+            key, value, cache, survivors, block_table, block_size,
+        )
+
+        assert counts[0] == 3
+        # Dest pos 0 → block 0, offset 0; pos 1 → block 0, offset 1;
+        # pos 2 → block 1, offset 0.
+        assert cache[0, 0, 0, 0, 0].item() == 0.0    # token 0
+        assert cache[0, 0, 1, 0, 0].item() == 200.0  # token 2
+        assert cache[0, 1, 0, 0, 0].item() == 400.0  # token 4
