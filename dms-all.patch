+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Integration tests for DMS with a real model checkpoint.
+
+Requires GPU and the local checkpoint at models/Qwen3-8B-DMS-8x-4bit-NF4.
+Run with: pytest tests/v1/attention/test_dms_integration.py -v -s
+
+These tests are slow (model loading) and require a GPU, so they are
+marked with @pytest.mark.gpu to allow filtering.
+"""
+
+import gc
+import os
+
+import pytest
+import torch
+
+# Skip entire module if no CUDA GPU available.
+if not torch.cuda.is_available():
+    pytest.skip("CUDA GPU required for DMS integration tests", allow_module_level=True)
+
+from vllm import LLM, SamplingParams
+
+# Path to the local NF4 checkpoint (relative to repo root).
+MODEL_PATH = os.path.join(
+    os.path.dirname(__file__), "..", "..", "..", "models", "Qwen3-8B-DMS-8x-4bit-NF4"
+)
+
+
+def _cleanup():
+    """Force GPU memory cleanup between tests."""
+    gc.collect()
+    torch.cuda.empty_cache()
+
+
+@pytest.fixture(scope="module")
+def dms_llm():
+    """Load the DMS model once for all tests in this module."""
+    if not os.path.isdir(MODEL_PATH):
+        pytest.skip(f"Model not found at {MODEL_PATH}")
+
+    llm = LLM(
+        model=MODEL_PATH,
+        quantization="bitsandbytes",
+        dtype="bfloat16",
+        max_model_len=2048,
+        enforce_eager=True,  # No CUDA graphs (DMS uses dynamic shapes)
+        gpu_memory_utilization=0.9,
+        trust_remote_code=False,
+    )
+    yield llm
+    del llm
+    _cleanup()
+
+
+class TestDMSModelLoads:
+    """Basic smoke tests: model loads, generates text, doesn't crash."""
+
+    def test_generates_text(self, dms_llm):
+        """Model produces non-empty output."""
+        params = SamplingParams(max_tokens=32, temperature=0.0)
+        outputs = dms_llm.generate(["Hello, world!"], params)
+
+        assert len(outputs) == 1
+        text = outputs[0].outputs[0].text
+        assert len(text) > 0, "Model produced empty output"
+        print(f"\nGenerated: {text!r}")
+
+    def test_generates_coherent_text(self, dms_llm):
+        """Model produces something that looks like language, not garbage."""
+        params = SamplingParams(max_tokens=64, temperature=0.0)
+        outputs = dms_llm.generate(
+            ["The capital of France is"],
+            params,
+        )
+
+        text = outputs[0].outputs[0].text.lower()
+        print(f"\nGenerated: {text!r}")
+        # Very loose check — just verify it's not random tokens.
+        assert len(text.split()) > 2, "Output too short to be coherent"
+
+    def test_multiple_prompts(self, dms_llm):
+        """Batch of prompts all produce output."""
+        prompts = [
+            "What is 2 + 2?",
+            "List three colors:",
+            "The quick brown fox",
+        ]
+        params = SamplingParams(max_tokens=32, temperature=0.0)
+        outputs = dms_llm.generate(prompts, params)
+
+        assert len(outputs) == len(prompts)
+        for i, out in enumerate(outputs):
+            text = out.outputs[0].text
+            assert len(text) > 0, f"Prompt {i} produced empty output"
+            print(f"\nPrompt {i}: {text!r}")
+
+    def test_longer_generation(self, dms_llm):
+        """Longer generation exercises the decode loop with eviction."""
+        params = SamplingParams(max_tokens=256, temperature=0.0)
+        outputs = dms_llm.generate(
+            ["Write a short paragraph about the ocean."],
+            params,
+        )
+
+        text = outputs[0].outputs[0].text
+        # 256 tokens should produce a decent amount of text.
+        assert len(text) > 50, f"Output too short ({len(text)} chars)"
+        print(f"\nGenerated ({len(text)} chars): {text[:200]!r}...")
+
+
+class TestDMSEviction:
+    """Verify that DMS eviction is actually happening."""
+
+    def test_long_context_completes(self, dms_llm):
+        """A long prompt + generation should complete without OOM,
+        demonstrating that DMS is compressing the cache."""
+        # Build a prompt that's moderately long.
+        prompt = "Summarize the following:\n" + "The cat sat on the mat. " * 100
+        params = SamplingParams(max_tokens=64, temperature=0.0)
+        outputs = dms_llm.generate([prompt], params)
+
+        text = outputs[0].outputs[0].text
+        assert len(text) > 0
+        print(f"\nLong context output: {text[:200]!r}")
