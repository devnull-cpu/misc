--- /dev/null
+++ b/vllm/v1/attention/dms/triton_dms_cache_update.py
@@ -0,0 +1,231 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Fused Triton kernel for DMS per-head cache update.
+
+Replaces ~30 individual tensor operations per layer per decode step with
+a single kernel launch. Each program handles one (request, head) pair and:
+1. Pops a free slot (or appends) to determine the write position
+2. Converts to physical block/offset via block_table
+3. Writes K/V to the paged cache
+4. Updates the DMS circular buffer and eviction tracking
+
+For Qwen3-8B: eliminates ~1080 tiny CUDA kernel dispatches per decode step
+(30 ops × 36 layers), which dominated the DMS overhead per the profiler.
+"""
+
+from __future__ import annotations
+
+import torch
+import triton
+import triton.language as tl
+
+
+@triton.jit
+def _dms_fused_cache_update_kernel(
+    # New K/V to write — (num_reqs, num_kv_heads, head_dim)
+    Key_ptr, Value_ptr,
+    # Paged KV cache — (num_blocks, block_size, num_kv_heads, head_dim)
+    K_cache_ptr, V_cache_ptr,
+    # Block table — (num_reqs, max_num_blocks_per_req), int32
+    block_table_ptr,
+    # Decisions — (num_reqs, num_kv_heads), float → stored as int64
+    decisions_ptr,
+    # DMS State tensors (in-place read/write)
+    free_slots_ptr,       # (page_batch, max_free), int64
+    free_slot_count_ptr,  # (page_batch,), int64
+    cache_seq_lens_ptr,   # (page_batch,), int32
+    circular_ptr_ptr,     # (page_batch,), int64
+    tokens_seen_ptr,      # (page_batch,), int64
+    recent_info_ptr,      # (page_batch, window_size, 2), int64
+    # Key strides
+    stride_kt, stride_kh, stride_kd,
+    # Value strides
+    stride_vt, stride_vh, stride_vd,
+    # K cache strides
+    stride_kcb, stride_kcs, stride_kch, stride_kcd,
+    # V cache strides
+    stride_vcb, stride_vcs, stride_vch, stride_vcd,
+    # Block table strides
+    stride_bt, stride_bb,
+    # Decisions strides
+    stride_dt, stride_dh,
+    # Free slots strides
+    stride_fsp, stride_fsf,
+    # Recent info strides
+    stride_rip, stride_riw, stride_ri2,
+    # Constants
+    BLOCK_SIZE: tl.constexpr,
+    HEAD_DIM: tl.constexpr,
+    WINDOW_SIZE: tl.constexpr,
+    NUM_KV_HEADS: tl.constexpr,
+):
+    """Fused DMS cache update: slot mapping + KV write + state update.
+
+    Grid: (num_reqs * num_kv_heads,)
+    Each program independently handles one (request, head) pair.
+    No cross-program data dependencies.
+    """
+    pid = tl.program_id(0)
+    req_idx = pid // NUM_KV_HEADS
+    head_idx = pid % NUM_KV_HEADS
+
+    # ================================================================
+    # Phase 1: Determine write position (pop free slot or append)
+    # ================================================================
+    free_count = tl.load(free_slot_count_ptr + pid)
+    has_free = free_count > 0
+
+    # Safe index for free slot read (clamp to 0 when empty).
+    pop_idx = tl.where(has_free, free_count - 1, 0)
+    free_slot_val = tl.load(
+        free_slots_ptr + pid * stride_fsp + pop_idx * stride_fsf
+    )
+
+    # Update free slot count (decrement if popped).
+    new_free_count = tl.where(has_free, free_count - 1, free_count)
+    tl.store(free_slot_count_ptr + pid, new_free_count)
+
+    # Write position: free slot if available, else append at seq_len.
+    seq_len = tl.load(cache_seq_lens_ptr + pid).to(tl.int64)
+    write_pos = tl.where(has_free, free_slot_val, seq_len)
+
+    # ================================================================
+    # Phase 2: Convert to physical block location
+    # ================================================================
+    logical_block = write_pos // BLOCK_SIZE
+    offset_in_block = write_pos % BLOCK_SIZE
+    phys_block = tl.load(
+        block_table_ptr + req_idx * stride_bt + logical_block * stride_bb
+    ).to(tl.int64)
+
+    # ================================================================
+    # Phase 3: Write K/V to paged cache
+    # ================================================================
+    d_offs = tl.arange(0, HEAD_DIM)
+
+    # Load new K and store to cache.
+    k_src = Key_ptr + req_idx * stride_kt + head_idx * stride_kh
+    k_vals = tl.load(k_src + d_offs * stride_kd)
+
+    k_dst = (K_cache_ptr + phys_block * stride_kcb
+             + offset_in_block * stride_kcs + head_idx * stride_kch)
+    tl.store(k_dst + d_offs * stride_kcd, k_vals)
+
+    # Load new V and store to cache.
+    v_src = Value_ptr + req_idx * stride_vt + head_idx * stride_vh
+    v_vals = tl.load(v_src + d_offs * stride_vd)
+
+    v_dst = (V_cache_ptr + phys_block * stride_vcb
+             + offset_in_block * stride_vcs + head_idx * stride_vch)
+    tl.store(v_dst + d_offs * stride_vcd, v_vals)
+
+    # ================================================================
+    # Phase 4: Update DMS state (circular buffer + eviction tracking)
+    # ================================================================
+    circ_ptr = tl.load(circular_ptr_ptr + pid)
+    tokens_seen = tl.load(tokens_seen_ptr + pid)
+    window_full = tokens_seen >= WINDOW_SIZE
+
+    # Read oldest entry in circular buffer.
+    ri_base = recent_info_ptr + pid * stride_rip + circ_ptr * stride_riw
+    oldest_pos = tl.load(ri_base)              # recent_info[pb, ptr, 0]
+    oldest_evict = tl.load(ri_base + stride_ri2)  # recent_info[pb, ptr, 1]
+
+    # Should we evict the oldest entry?
+    should_evict = window_full & (oldest_evict == 1)
+
+    # Push evicted slot to free list.
+    # Always write to free_slots at current count position (harmless if
+    # not evicting since count won't increase, leaving the write as dead).
+    cur_free_count = tl.load(free_slot_count_ptr + pid)
+    tl.store(
+        free_slots_ptr + pid * stride_fsp + cur_free_count * stride_fsf,
+        oldest_pos,
+    )
+    push_count = tl.where(should_evict, cur_free_count + 1, cur_free_count)
+    tl.store(free_slot_count_ptr + pid, push_count)
+
+    # Write new entry to circular buffer at current pointer position.
+    decision_val = tl.load(
+        decisions_ptr + req_idx * stride_dt + head_idx * stride_dh
+    )
+    tl.store(ri_base, write_pos)
+    tl.store(ri_base + stride_ri2, decision_val.to(tl.int64))
+
+    # Advance circular pointer (modular).
+    tl.store(circular_ptr_ptr + pid, (circ_ptr + 1) % WINDOW_SIZE)
+
+    # Increment tokens seen.
+    tl.store(tokens_seen_ptr + pid, tokens_seen + 1)
+
+    # Update cache_seq_lens: grows by 1 only when no eviction.
+    new_seq_len = tl.where(should_evict, seq_len, seq_len + 1)
+    tl.store(cache_seq_lens_ptr + pid, new_seq_len.to(tl.int32))
+
+
+def dms_fused_cache_update(
+    key: torch.Tensor,
+    value: torch.Tensor,
+    key_cache: torch.Tensor,
+    value_cache: torch.Tensor,
+    block_table: torch.Tensor,
+    decisions: torch.Tensor,
+    dms_state,  # DMSState
+    num_reqs: int,
+) -> None:
+    """Launch the fused DMS cache update kernel.
+
+    Args:
+        key: New K values, (num_reqs, num_kv_heads, head_dim).
+        value: New V values, same shape.
+        key_cache: Paged K cache, (num_blocks, block_size, num_kv_heads, head_dim).
+        value_cache: Same shape.
+        block_table: (num_reqs, max_num_blocks_per_req), int32.
+        decisions: Binary eviction decisions, (num_reqs, num_kv_heads), float.
+        dms_state: DMSState instance with circular buffer and free lists.
+        num_reqs: Number of requests in this batch.
+    """
+    num_kv_heads = dms_state.num_kv_heads
+    block_size = key_cache.shape[1]
+    head_dim = key.shape[-1]
+    head_dim_padded = triton.next_power_of_2(head_dim)
+
+    grid = (num_reqs * num_kv_heads,)
+
+    _dms_fused_cache_update_kernel[grid](
+        key, value,
+        key_cache, value_cache,
+        block_table,
+        decisions,
+        # DMS State tensors
+        dms_state.free_slots,
+        dms_state.free_slot_count,
+        dms_state.cache_seq_lens,
+        dms_state.circular_ptr,
+        dms_state.tokens_seen,
+        dms_state.recent_info,
+        # Key strides
+        key.stride(0), key.stride(1), key.stride(2),
+        # Value strides
+        value.stride(0), value.stride(1), value.stride(2),
+        # K cache strides
+        key_cache.stride(0), key_cache.stride(1),
+        key_cache.stride(2), key_cache.stride(3),
+        # V cache strides
+        value_cache.stride(0), value_cache.stride(1),
+        value_cache.stride(2), value_cache.stride(3),
+        # Block table strides
+        block_table.stride(0), block_table.stride(1),
+        # Decisions strides
+        decisions.stride(0), decisions.stride(1),
+        # Free slots strides
+        dms_state.free_slots.stride(0), dms_state.free_slots.stride(1),
+        # Recent info strides
+        dms_state.recent_info.stride(0), dms_state.recent_info.stride(1),
+        dms_state.recent_info.stride(2),
+        # Constants
+        BLOCK_SIZE=block_size,
+        HEAD_DIM=head_dim_padded,
+        WINDOW_SIZE=dms_state.window_size,
+        NUM_KV_HEADS=num_kv_heads,
+    )
