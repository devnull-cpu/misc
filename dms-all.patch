+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Benchmark DMS at longer contexts (4K-8K) to measure real compression.
+
+At 2K context, DMS compression is ~2x. The value proposition is at longer
+contexts where compression should approach the configured 8x ratio.
+
+Usage:
+    python tests/v1/attention/bench_long_context.py 4096
+    python tests/v1/attention/bench_long_context.py 8192
+    python tests/v1/attention/bench_long_context.py all
+"""
+
+import gc
+import os
+import sys
+import time
+
+os.environ["VLLM_ENABLE_V1_MULTIPROCESSING"] = "0"
+
+from vllm import LLM, SamplingParams
+from vllm.v1.attention.backends.dms_flash_attn import DMSFlashAttentionImpl
+
+MODEL_PATH = os.path.normpath(os.path.join(
+    os.path.dirname(os.path.abspath(__file__)),
