diff --git a/vllm/v1/attention/dms/triton_dms_decode_v2.py b/vllm/v1/attention/dms/triton_dms_decode_v2.py
new file mode 100644
index 000000000..e1ce5dfa6
--- /dev/null
+++ b/vllm/v1/attention/dms/triton_dms_decode_v2.py
@@ -0,0 +1,397 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Split-K Triton decode kernel for DMS per-head attention.
+
+Adapted from vllm/v1/attention/ops/triton_decode_attention.py (which was
+adapted from sglang/lightllm). Key changes:
+
+  1. Per-head sequence lengths: B_Seqlen is (batch * num_kv_heads,) instead
+     of (batch,). Each KV head can have a different cache length due to DMS
+     per-head eviction.
+
+  2. Split-K parallelism: KV cache is split into NUM_KV_SPLITS chunks,
+     each processed by a separate program. Stage 2 reduces partial results.
+     This gives better SM occupancy than the v1 sequential approach.
+
+  3. Grouped head processing: BLOCK_H query heads processed per program
+     with tl.dot (tensor cores) instead of element-wise tl.sum.
+
+For Qwen3-8B (32 Q heads, 8 KV heads, GQA ratio 4):
+  - v1: 32*batch programs, sequential over all blocks
+  - v2: 8*batch*NUM_KV_SPLITS stage1 programs + 32*batch stage2 programs
+"""
+
+from __future__ import annotations
+
+import torch
+import triton
+import triton.language as tl
+
+
+@triton.jit
+def _dms_decode_stage1(
+    Q,
+    K_Buffer,
+    V_Buffer,
+    sm_scale,
+    Block_table,        # (num_reqs, max_num_blocks_per_req), int32
+    B_Seqlen,           # (num_reqs * num_kv_heads,), int32 — per-head
+    Att_Out,            # intermediate: (batch, q_head_num, NUM_KV_SPLITS, Lv+1)
+    stride_bt_b,        # block_table stride per request
+    stride_qbs,
+    stride_qh,
+    stride_buf_kbs,     # K cache: stride of slot dimension
+    stride_buf_kh,      # K cache: stride of head dimension
+    stride_buf_vbs,
+    stride_buf_vh,
+    stride_mid_ob,
+    stride_mid_oh,
+    stride_mid_os,
+    NUM_KV_HEADS: tl.constexpr,
+    kv_group_num: tl.constexpr,
+    q_head_num: tl.constexpr,
+    BLOCK_DMODEL: tl.constexpr,
+    BLOCK_DV: tl.constexpr,
+    BLOCK_N: tl.constexpr,
+    BLOCK_H: tl.constexpr,
+    NUM_KV_SPLITS: tl.constexpr,
+    PAGE_SIZE: tl.constexpr,
+    Lk: tl.constexpr,
+    Lv: tl.constexpr,
+):
+    cur_batch = tl.program_id(0)
+    cur_head_id = tl.program_id(1)
+    split_kv_id = tl.program_id(2)
+
+    cur_kv_head = cur_head_id // tl.cdiv(kv_group_num, BLOCK_H)
+
+    VALID_BLOCK_H: tl.constexpr = (
+        BLOCK_H if kv_group_num > BLOCK_H else kv_group_num
+    )
+    cur_head = cur_head_id * VALID_BLOCK_H + tl.arange(0, BLOCK_H)
+    mask_h = cur_head < (cur_head_id + 1) * VALID_BLOCK_H
+    mask_h = mask_h & (cur_head < q_head_num)
+
+    offs_d = tl.arange(0, BLOCK_DMODEL)
+    offs_dv = tl.arange(0, BLOCK_DV)
+    mask_d = offs_d < Lk
+    mask_dv = offs_dv < Lv
+
+    # DMS: per-head sequence length.
+    cur_batch_seq_len = tl.load(
+        B_Seqlen + cur_batch * NUM_KV_HEADS + cur_kv_head
+    )
+
+    # Early return for padding (CUDAGraph).
+    if cur_batch_seq_len <= 0:
+        return
+
+    # Load Q vectors for this head group.
+    offs_q = (
+        cur_batch * stride_qbs
+        + cur_head[:, None] * stride_qh
+        + offs_d[None, :]
+    )
+    q = tl.load(
+        Q + offs_q,
+        mask=(mask_h[:, None]) & (mask_d[None, :]),
+        other=0.0,
+    )
+
+    # Split-K: this program handles [split_kv_start, split_kv_end).
+    kv_len_per_split = tl.cdiv(cur_batch_seq_len, NUM_KV_SPLITS)
+    split_kv_start = kv_len_per_split * split_kv_id
+    split_kv_end = tl.minimum(
+        split_kv_start + kv_len_per_split, cur_batch_seq_len
+    )
+
+    e_max = tl.zeros([BLOCK_H], dtype=tl.float32) - float("inf")
+    e_sum = tl.zeros([BLOCK_H], dtype=tl.float32)
+    acc = tl.zeros([BLOCK_H, BLOCK_DV], dtype=tl.float32)
+
+    if split_kv_end > split_kv_start:
+        for start_n in range(split_kv_start, split_kv_end, BLOCK_N):
+            offs_n = start_n + tl.arange(0, BLOCK_N)
+
+            # Look up physical block from block table.
+            kv_page_number = tl.load(
+                Block_table
+                + cur_batch * stride_bt_b
+                + offs_n // PAGE_SIZE,
+                mask=offs_n < split_kv_end,
+                other=0,
+            )
+            kv_loc = kv_page_number * PAGE_SIZE + offs_n % PAGE_SIZE
+
+            # Load K: (BLOCK_DMODEL, BLOCK_N)
+            offs_buf_k = (
+                kv_loc[None, :] * stride_buf_kbs
+                + cur_kv_head * stride_buf_kh
+                + offs_d[:, None]
+            )
+            k = tl.load(
+                K_Buffer + offs_buf_k,
+                mask=(offs_n[None, :] < split_kv_end) & (mask_d[:, None]),
+                other=0.0,
+            )
+
+            # QK: (BLOCK_H, BLOCK_N) via tl.dot (tensor cores).
+            qk = tl.dot(q, k.to(q.dtype))
+            qk *= sm_scale
+
+            qk = tl.where(
+                mask_h[:, None] & (offs_n[None, :] < split_kv_end),
+                qk,
+                float("-inf"),
+            )
+
+            # Load V: (BLOCK_N, BLOCK_DV)
+            offs_buf_v = (
+                kv_loc[:, None] * stride_buf_vbs
+                + cur_kv_head * stride_buf_vh
+                + offs_dv[None, :]
+            )
+            v = tl.load(
+                V_Buffer + offs_buf_v,
+                mask=(offs_n[:, None] < split_kv_end) & (mask_dv[None, :]),
+                other=0.0,
+            )
+
+            # Online softmax update.
+            n_e_max = tl.maximum(tl.max(qk, 1), e_max)
+            re_scale = tl.exp(e_max - n_e_max)
+            p = tl.exp(qk - n_e_max[:, None])
+            acc *= re_scale[:, None]
+            acc += tl.dot(p.to(v.dtype), v)
+
+            e_sum = e_sum * re_scale + tl.sum(p, 1)
+            e_max = n_e_max
+
+        # Store partial result: normalized output + log-sum-exp.
+        offs_mid_o = (
+            cur_batch * stride_mid_ob
+            + cur_head[:, None] * stride_mid_oh
+            + split_kv_id * stride_mid_os
+            + offs_dv[None, :]
+        )
+        tl.store(
+            Att_Out + offs_mid_o,
+            acc / e_sum[:, None],
+            mask=(mask_h[:, None]) & (mask_dv[None, :]),
+        )
+
+        offs_mid_o_1 = (
+            cur_batch * stride_mid_ob
+            + cur_head * stride_mid_oh
+            + split_kv_id * stride_mid_os
+            + Lv
+        )
+        tl.store(
+            Att_Out + offs_mid_o_1,
+            e_max + tl.log(e_sum),
+            mask=mask_h,
+        )
+
+
+@triton.jit
+def _dms_decode_stage2(
+    Mid_O,
+    o,
+    B_Seqlen,           # (num_reqs * num_kv_heads,), int32 — per-head
+    stride_mid_ob,
+    stride_mid_oh,
+    stride_mid_os,
+    stride_obs,
+    stride_oh,
+    NUM_KV_HEADS: tl.constexpr,
+    kv_group_num: tl.constexpr,
+    NUM_KV_SPLITS: tl.constexpr,
+    BLOCK_DV: tl.constexpr,
+    Lv: tl.constexpr,
+):
+    cur_batch = tl.program_id(0)
+    cur_head = tl.program_id(1)
+
+    # DMS: per-head sequence length.
+    cur_kv_head = cur_head // kv_group_num
+    cur_batch_seq_len = tl.load(
+        B_Seqlen + cur_batch * NUM_KV_HEADS + cur_kv_head
+    )
+
+    offs_d = tl.arange(0, BLOCK_DV)
+    mask_d = offs_d < Lv
+
+    e_sum = 0.0
+    e_max = -float("inf")
+    acc = tl.zeros([BLOCK_DV], dtype=tl.float32)
+
+    offs_v = cur_batch * stride_mid_ob + cur_head * stride_mid_oh + offs_d
+    offs_logic = cur_batch * stride_mid_ob + cur_head * stride_mid_oh + Lv
+
+    for split_kv_id in range(0, NUM_KV_SPLITS):
+        kv_len_per_split = tl.cdiv(cur_batch_seq_len, NUM_KV_SPLITS)
+        split_kv_start = kv_len_per_split * split_kv_id
+        split_kv_end = tl.minimum(
+            split_kv_start + kv_len_per_split, cur_batch_seq_len
+        )
+
+        if split_kv_end > split_kv_start:
+            tv = tl.load(
+                Mid_O + offs_v + split_kv_id * stride_mid_os,
+                mask=mask_d,
+                other=0.0,
+            )
+            tlogic = tl.load(
+                Mid_O + offs_logic + split_kv_id * stride_mid_os
+            )
+            n_e_max = tl.maximum(tlogic, e_max)
+
+            old_scale = tl.exp(e_max - n_e_max)
+            acc *= old_scale
+            exp_logic = tl.exp(tlogic - n_e_max)
+            acc += exp_logic * tv
+
+            e_sum = e_sum * old_scale + exp_logic
+            e_max = n_e_max
+
+    # Write final output.
+    e_sum = tl.where(e_sum > 0.0, e_sum, 1.0)
+    tl.store(
+        o + cur_batch * stride_obs + cur_head * stride_oh + offs_d,
+        acc / e_sum,
+        mask=mask_d,
+    )
+
+
+def dms_paged_decode_attention_v2(
+    query: torch.Tensor,
+    key_cache: torch.Tensor,
+    value_cache: torch.Tensor,
+    output: torch.Tensor,
+    block_table: torch.Tensor,
+    per_head_seq_lens: torch.Tensor,
+    num_kv_heads: int,
+    num_q_heads: int,
+    head_size: int,
+    scale: float,
+    max_num_blocks: int | None = None,
+    num_kv_splits: int = 8,
+    _att_out_buf: torch.Tensor | None = None,
+) -> torch.Tensor:
+    """Split-K Triton decode with per-head sequence lengths.
+
+    Drop-in replacement for dms_paged_decode_attention with Split-K
+    parallelism and grouped head processing (tl.dot / tensor cores).
+
+    Args:
+        query: (num_reqs, num_q_heads, head_size).
+        key_cache: (num_blocks, block_size, num_kv_heads, head_size).
+        value_cache: same shape as key_cache.
+        output: (num_reqs, num_q_heads, head_size) — written in-place.
+        block_table: (num_reqs, max_num_blocks_per_req), int32.
+        per_head_seq_lens: (num_reqs * num_kv_heads,), int32.
+        num_kv_heads: number of KV heads.
+        num_q_heads: number of query heads.
+        head_size: dimension per head.
+        scale: softmax scale factor.
+        max_num_blocks: unused (kept for API compat with v1).
+        num_kv_splits: number of KV cache splits for parallelism.
+        _att_out_buf: pre-allocated intermediate buffer for CUDAGraph.
+            Shape: (num_reqs, num_q_heads, num_kv_splits, head_size + 1).
+
+    Returns:
+        output tensor (written in-place).
+    """
+    num_reqs = query.shape[0]
+    if num_reqs == 0:
+        return output
+
+    if not hasattr(dms_paged_decode_attention_v2, "_logged"):
+        dms_paged_decode_attention_v2._logged = True
+        print(
+            f"\n[DMS Triton decode v2] ACTIVE — Split-K={num_kv_splits}, "
+            f"num_reqs={num_reqs}, block_table={block_table.shape}"
+        )
+
+    Lk = head_size
+    Lv = head_size
+    page_size = key_cache.shape[1]
+    kv_group_num = num_q_heads // num_kv_heads
+
+    BLOCK_N = 32
+    BLOCK_H = 16
+    BLOCK_DMODEL = triton.next_power_of_2(Lk)
+    BLOCK_DV = triton.next_power_of_2(Lv)
+
+    # Intermediate buffer for partial results.
+    if _att_out_buf is not None:
+        att_out = _att_out_buf[:num_reqs]
+    else:
+        att_out = torch.empty(
+            (num_reqs, num_q_heads, num_kv_splits, Lv + 1),
+            dtype=torch.float32,
+            device=query.device,
+        )
+
+    # Stage 1: parallel over (batch, head_groups, kv_splits).
+    grid_s1 = (
+        num_reqs,
+        triton.cdiv(num_q_heads, min(BLOCK_H, kv_group_num)),
+        num_kv_splits,
+    )
+
+    _dms_decode_stage1[grid_s1](
+        query,
+        key_cache,
+        value_cache,
+        scale,
+        block_table,
+        per_head_seq_lens,
+        att_out,
+        block_table.stride(0),
+        query.stride(0),
+        query.stride(1),
+        key_cache.stride(1),   # slot stride
+        key_cache.stride(2),   # head stride
+        value_cache.stride(1),
+        value_cache.stride(2),
+        att_out.stride(0),
+        att_out.stride(1),
+        att_out.stride(2),
+        NUM_KV_HEADS=num_kv_heads,
+        kv_group_num=kv_group_num,
+        q_head_num=num_q_heads,
+        BLOCK_DMODEL=BLOCK_DMODEL,
+        BLOCK_DV=BLOCK_DV,
+        BLOCK_N=BLOCK_N,
+        BLOCK_H=BLOCK_H,
+        NUM_KV_SPLITS=num_kv_splits,
+        PAGE_SIZE=page_size,
+        Lk=Lk,
+        Lv=Lv,
+        num_warps=4,
+        num_stages=2,
+    )
+
+    # Stage 2: reduce across splits.
+    grid_s2 = (num_reqs, num_q_heads)
+
+    _dms_decode_stage2[grid_s2](
+        att_out,
+        output,
+        per_head_seq_lens,
+        att_out.stride(0),
+        att_out.stride(1),
+        att_out.stride(2),
+        output.stride(0),
+        output.stride(1),
+        NUM_KV_HEADS=num_kv_heads,
+        kv_group_num=kv_group_num,
+        NUM_KV_SPLITS=num_kv_splits,
+        BLOCK_DV=BLOCK_DV,
+        Lv=Lv,
+        num_warps=4,
+        num_stages=2,
+    )
+
+    return output
