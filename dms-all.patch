--- /dev/null
+++ b/vllm/v1/attention/dms/dms_state.py
@@ -0,0 +1,244 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""DMS state management: circular buffer, eviction tracking, slot recycling.
+
+This module is model-agnostic — it operates on tensors of eviction decisions
+and cache positions, independent of any specific model architecture.
+
+Reference: Model Optimizer cache_paged.py lines 83-167 (_aux_update_single),
+           kvcompress dms_cache.py lines 63-148.
+"""
+
+from __future__ import annotations
+
+import torch
+
+from vllm.config.dms import DMSConfig
+
+
+class DMSState:
+    """Per-layer DMS state for managing compressed KV cache.
+
+    Uses the batch×head flattening trick: the first dimension is
+    ``page_batch = batch_size * num_kv_heads``, so each (request, head) pair
+    gets its own circular buffer, eviction tracking, and block table row.
+
+    Attributes:
+        recent_info: Circular buffer of shape ``(page_batch, window_size, 2)``
+            where ``[..., 0]`` = cache position (slot index),
+            ``[..., 1]`` = eviction flag (0=keep, 1=evict).
+        cache_seq_lens: Actual number of KV entries per (batch, head),
+            shape ``(page_batch,)``.
+        circular_ptr: Current write position in the circular buffer,
+            shape ``(page_batch,)``.
+        free_slots: Stack of freed slot indices per (batch, head).
+            Implemented as a tensor with a pointer for each page_batch entry.
+    """
+
+    def __init__(
+        self,
+        dms_config: DMSConfig,
+        batch_size: int,
+        num_kv_heads: int,
+        max_seq_len: int,
+        block_size: int,
+        device: torch.device,
+    ):
+        self.dms_config = dms_config
+        self.batch_size = batch_size
+        self.num_kv_heads = num_kv_heads
+        self.page_batch = batch_size * num_kv_heads
+        self.window_size = dms_config.dms_window_size
+        self.block_size = block_size
+        self.device = device
+
+        # Circular buffer: tracks (cache_position, eviction_flag) for
+        # each of the last `window_size` tokens per (batch, head).
+        self.recent_info = torch.zeros(
+            self.page_batch, self.window_size, 2,
+            dtype=torch.long, device=device,
+        )
+
+        # Per-(batch, head) actual cache sequence length.
+        self.cache_seq_lens = torch.zeros(
+            self.page_batch, dtype=torch.int32, device=device,
+        )
+
+        # Circular pointer into recent_info per (batch, head).
+        self.circular_ptr = torch.zeros(
+            self.page_batch, dtype=torch.long, device=device,
+        )
+
+        # Free slot stack per (batch, head).
+        # Pre-allocate for worst case: max_seq_len slots could be freed.
+        max_free = max(max_seq_len, self.window_size)
+        self.free_slots = torch.zeros(
+            self.page_batch, max_free, dtype=torch.long, device=device,
+        )
+        self.free_slot_count = torch.zeros(
+            self.page_batch, dtype=torch.long, device=device,
+        )
+
+        # Total tokens seen (monotonically increasing), used for
+        # determining whether the window is full.
+        self.tokens_seen = torch.zeros(
+            self.page_batch, dtype=torch.long, device=device,
+        )
+
+    def reset_request(self, req_idx: int) -> None:
+        """Reset DMS state for a request that has been removed or replaced."""
+        start = req_idx * self.num_kv_heads
+        end = start + self.num_kv_heads
+        self.recent_info[start:end].zero_()
+        self.cache_seq_lens[start:end].zero_()
+        self.circular_ptr[start:end].zero_()
+        self.free_slots[start:end].zero_()
+        self.free_slot_count[start:end].zero_()
+        self.tokens_seen[start:end].zero_()
+
+    def update_decode(
+        self,
+        decisions: torch.Tensor,
+        new_cache_positions: torch.Tensor,
+    ) -> tuple[torch.Tensor, torch.Tensor]:
+        """Update DMS state for a single decode step.
+
+        Implements the shift-by-one delayed eviction logic:
+        1. The eviction decision from this step applies to the *previous*
+           token's KV pair (the one written ``window_size`` steps ago).
+        2. Record the new token in the circular buffer.
+        3. If the oldest entry in the window is marked for eviction,
+           push its cache slot to the free list.
+
+        Args:
+            decisions: Binary eviction decisions, shape ``(batch, num_kv_heads)``.
+                1 = evict (after delay), 0 = keep.
+            new_cache_positions: Cache slot positions where new KV pairs were
+                written, shape ``(batch, num_kv_heads)``.
+
+        Returns:
+            evicted_slots: Slot indices that were evicted this step,
+                shape ``(page_batch,)``. -1 for entries where no eviction
+                occurred.
+            grew: Boolean tensor, shape ``(page_batch,)``. True if cache
+                grew (no eviction), False if a slot was recycled.
+        """
+        page_batch = self.page_batch
+        decisions_flat = decisions.reshape(page_batch)
+        positions_flat = new_cache_positions.reshape(page_batch)
+
+        # Determine the index of the oldest entry in the circular buffer.
+        ptr = self.circular_ptr  # (page_batch,)
+        oldest_idx = ptr  # Will be overwritten next
+
+        # Check if the window is full (we've seen at least window_size tokens).
+        window_full = self.tokens_seen >= self.window_size
+
+        # Read the oldest entry (only valid if window is full).
+        oldest_pos = self.recent_info[
+            torch.arange(page_batch, device=self.device), oldest_idx, 0
+        ]
+        oldest_evict = self.recent_info[
+            torch.arange(page_batch, device=self.device), oldest_idx, 1
+        ]
+
+        # Determine which entries should actually be evicted:
+        # window must be full AND the oldest entry was marked for eviction.
+        should_evict = window_full & (oldest_evict == 1)
+
+        # Record evicted slots.
+        evicted_slots = torch.where(
+            should_evict, oldest_pos, torch.tensor(-1, device=self.device)
+        )
+
+        # Push evicted slots to free list.
+        evict_indices = should_evict.nonzero(as_tuple=True)[0]
+        if evict_indices.numel() > 0:
+            counts = self.free_slot_count[evict_indices]
+            self.free_slots[evict_indices, counts] = oldest_pos[evict_indices]
+            self.free_slot_count[evict_indices] = counts + 1
+
+        # Write new entry to circular buffer at current pointer position.
+        batch_indices = torch.arange(page_batch, device=self.device)
+        self.recent_info[batch_indices, ptr, 0] = positions_flat
+        self.recent_info[batch_indices, ptr, 1] = decisions_flat.to(torch.long)
+
+        # Advance circular pointer.
+        self.circular_ptr = (ptr + 1) % self.window_size
+
+        # Update tokens seen count.
+        self.tokens_seen += 1
+
+        # Update cache sequence lengths:
+        # If we evicted, length stays the same (slot recycled).
+        # If we didn't evict, length grows by 1.
+        grew = ~should_evict
+        self.cache_seq_lens += grew.to(torch.int32)
+
+        return evicted_slots, grew
+
+    def pop_free_slot(
+        self, page_batch_indices: torch.Tensor
+    ) -> torch.Tensor:
+        """Pop a free slot from the free list for given page_batch entries.
+
+        Args:
+            page_batch_indices: Indices into page_batch dimension.
+
+        Returns:
+            Slot indices popped from the free list. -1 if no free slot.
+        """
+        counts = self.free_slot_count[page_batch_indices]
+        has_free = counts > 0
+        new_counts = torch.where(has_free, counts - 1, counts)
+        self.free_slot_count[page_batch_indices] = new_counts
+        slots = torch.where(
+            has_free,
+            self.free_slots[page_batch_indices, new_counts],
+            torch.tensor(-1, dtype=torch.long, device=self.device),
+        )
+        return slots
+
+    def get_decode_slot_mapping(
+        self,
+        req_indices: torch.Tensor,
+    ) -> torch.Tensor:
+        """Compute per-head slot mapping for decode.
+
+        For each (request, head): if there's a free slot from eviction,
+        reuse it; otherwise append at cache_seq_lens position.
+
+        Args:
+            req_indices: Request indices in the batch, shape ``(num_tokens,)``.
+                For decode, this is typically one token per request.
+
+        Returns:
+            slot_mapping: Shape ``(num_tokens, num_kv_heads)`` — the cache
+                slot where each head's new KV pair should be written.
+        """
+        num_tokens = req_indices.shape[0]
+        # Expand to page_batch indices
+        # req_indices shape: (num_tokens,)
+        # For each req, we have num_kv_heads entries
+        head_indices = torch.arange(
+            self.num_kv_heads, device=self.device
+        ).unsqueeze(0).expand(num_tokens, -1)
+        page_indices = (
+            req_indices.unsqueeze(1) * self.num_kv_heads + head_indices
+        )  # (num_tokens, num_kv_heads)
+
+        # Try to pop free slots
+        page_indices_flat = page_indices.reshape(-1)
+        free = self.pop_free_slot(page_indices_flat)
+        free = free.reshape(num_tokens, self.num_kv_heads)
+
+        # For entries without free slots, use current cache_seq_lens
+        seq_lens = self.cache_seq_lens[page_indices_flat].reshape(
+            num_tokens, self.num_kv_heads
+        )
+
+        # Slot = free_slot if available, else seq_lens (append position).
+        # The actual block/offset mapping is handled by the caller.
+        slot_mapping = torch.where(free >= 0, free, seq_lens.to(torch.long))
+
+        return slot_mapping
-- 
