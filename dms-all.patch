+
+    DMSFlashAttentionImpl._do_cache_update = timed_cache_update
+
+    # --- 2. Time the full DMS forward (cache_update + triton decode) ---
+    orig_forward = DMSFlashAttentionImpl.forward
+
+    def timed_forward(self, layer, query, key, value, kv_cache, attn_metadata,
+                      output=None, output_scale=None, output_block_scale=None):
+        is_decode = attn_metadata is not None and attn_metadata.max_query_len == 1
+        if is_decode and self._dms_state is not None:
+            TIMER.start("2_dms_forward_total")
+            result = orig_forward(self, layer, query, key, value, kv_cache,
