+
+
+class CudaTimer:
+    """Accumulates GPU-side timing for named sections."""
+
+    def __init__(self):
+        self.totals = defaultdict(float)
+        self.counts = defaultdict(int)
+        self._start_events = {}
+
+    def start(self, name: str):
+        ev = torch.cuda.Event(enable_timing=True)
+        ev.record()
+        self._start_events[name] = ev
+
+    def stop(self, name: str):
+        end_ev = torch.cuda.Event(enable_timing=True)
+        end_ev.record()
+        torch.cuda.synchronize()
+        elapsed = self._start_events[name].elapsed_time(end_ev)
+        self.totals[name] += elapsed
+        self.counts[name] += 1
+
+    def report(self, num_tokens: int):
+        print("\n" + "=" * 70)
+        print("DMS DECODE PROFILE (GPU-timed)")
+        print("=" * 70)
+        total_ms = sum(self.totals.values())
+        for name in sorted(self.totals.keys()):
+            ms = self.totals[name]
+            count = self.counts[name]
+            per_call = ms / count if count > 0 else 0
+            per_tok = ms / num_tokens if num_tokens > 0 else 0
+            pct = ms / total_ms * 100 if total_ms > 0 else 0
+            print(f"  {name:45s}: {ms:8.1f} ms total, "
+                  f"{per_call:6.3f} ms/call, "
+                  f"{per_tok:6.3f} ms/tok, "
+                  f"{pct:5.1f}%  ({count} calls)")
+        print(f"  {'TOTAL':45s}: {total_ms:8.1f} ms")
+        if num_tokens > 0:
+            print(f"\n  Per-token overhead (instrumented): {total_ms / num_tokens:.2f} ms")
+        print()
+
+
+TIMER = CudaTimer()
+_patching_done = False
+
+
+def patch_timing():
+    """Monkey-patch timing into DMS hot path + model layer."""
+    global _patching_done
+    if _patching_done:
+        return
+    _patching_done = True
+
+    from vllm.v1.attention.backends.dms_flash_attn import DMSFlashAttentionImpl
+
+    # --- 1. Time cache_update (fused Triton kernel) ---
+    orig_do_cache = DMSFlashAttentionImpl._do_cache_update
+
+    def timed_cache_update(self, layer, key, value, kv_cache, attn_metadata, is_decode):
+        if is_decode and self._dms_state is not None:
+            TIMER.start("1_cache_update")
+            orig_do_cache(self, layer, key, value, kv_cache, attn_metadata, is_decode)
