+def _get_compression_stats():
+    """Collect compression stats from all DMS layers."""
+    instances = DMSFlashAttentionImpl._all_instances
+    if not instances:
+        return None
+
+    ratios = []
+    spreads = []
+    for impl in instances:
+        state = impl._dms_state
+        if state is None:
+            continue
+        num_kv_heads = impl.num_kv_heads
+        seq_lens = state.cache_seq_lens[:num_kv_heads].cpu().tolist()
+        tokens_seen = state.tokens_seen[:num_kv_heads].cpu().tolist()
+
+        for h in range(num_kv_heads):
+            if seq_lens[h] > 0 and tokens_seen[h] > 0:
+                ratios.append(tokens_seen[h] / seq_lens[h])
+
+        spread = max(seq_lens) - min(seq_lens) if seq_lens else 0
+        spreads.append(spread)
+
+    if not ratios:
+        return None
+
+    return {
+        "avg_ratio": sum(ratios) / len(ratios),
+        "min_ratio": min(ratios),
+        "max_ratio": max(ratios),
+        "avg_spread": sum(spreads) / len(spreads) if spreads else 0,
+        "max_spread": max(spreads) if spreads else 0,
+        "num_layers": len(instances),
