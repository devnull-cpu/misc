@@ -0,0 +1,730 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""DMS (Dynamic Memory Sparsification) attention backend.
+
+Extends FlashAttention with per-head KV cache management via
+the batch×head flattening trick. Decode uses standard
+``flash_attn_varlen_func`` on the flattened dimension.
+Prefill uses a two-pass approach initially (Phase 1).
+
+Wiring overview (data flow per layer per step):
+
+  Prefill:
+    1. Model layer extracts decisions, stores in ForwardContext
+    2. do_kv_cache_update: standard reshape_and_cache (all tokens)
+    3. forward: standard flash_attn_varlen_func
+    4. Post-prefill compaction: compute survivors per head,
+       compact KV cache in-place, initialize DMSState circular buffer
+
+  Decode:
+    1. Model layer extracts decisions, stores in ForwardContext
+    2. do_kv_cache_update: reads decisions from PREVIOUS step's
+       ForwardContext (stored on impl), determines per-head write
+       positions via DMSState, writes K/V per-head using direct
+       tensor indexing, then updates DMSState with current decisions
+    3. forward: reads DMSState.cache_seq_lens, builds per-head
+       block_table (request block_table repeated per head), uses
+       batch×head flattened flash_attn_varlen_func
+
+Reference: Model Optimizer attention.py lines 230-240,
+           cache_paged.py batch×head flattening.
+"""
+
+from __future__ import annotations
+
+import copy
+from dataclasses import dataclass
+from typing import ClassVar
+
+import torch
+
+from vllm.config import VllmConfig, get_current_vllm_config
+from vllm.config.dms import DMSConfig
+from vllm.forward_context import get_forward_context
+from vllm.logger import init_logger
+from vllm.v1.attention.dms import DMS_DECISIONS_KEY
+from vllm.v1.attention.backend import (
+    AttentionBackend,
+    AttentionCGSupport,
+    AttentionImpl,
+    AttentionMetadataBuilder,
+    AttentionType,
+    CommonAttentionMetadata,
+    MultipleOf,
+    is_quantized_kv_cache,
+)
+from vllm.v1.attention.backends.fa_utils import (
+    flash_attn_supports_fp8,
+    get_flash_attn_version,
+    is_flash_attn_varlen_func_available,
+)
+from vllm.v1.attention.dms.dms_state import DMSState
+from vllm.v1.kv_cache_interface import AttentionSpec
+
+if is_flash_attn_varlen_func_available():
+    from vllm.v1.attention.backends.fa_utils import (
+        flash_attn_varlen_func,
+        reshape_and_cache_flash,
+    )
+
+logger = init_logger(__name__)
+
+
+class DMSFlashAttentionBackend(AttentionBackend):
+    """DMS-aware FlashAttention backend.
+
+    Uses the same KV cache layout as FlashAttention but manages
+    per-head block tables and sequence lengths for DMS eviction.
+    """
+
+    accept_output_buffer: bool = True
+    supported_dtypes: ClassVar[list[torch.dtype]] = [
+        torch.float16,
+        torch.bfloat16,
+    ]
+
+    forward_includes_kv_cache_update: bool = False
+
+    @staticmethod
+    def get_supported_kernel_block_sizes() -> list[int | MultipleOf]:
+        return [MultipleOf(16)]
+
+    @staticmethod
+    def get_name() -> str:
+        return "DMS_FLASH_ATTN"
+
+    @classmethod
+    def supports_attn_type(cls, attn_type: str) -> bool:
+        return attn_type == AttentionType.DECODER
+
+    @staticmethod
+    def get_impl_cls() -> type[DMSFlashAttentionImpl]:
+        return DMSFlashAttentionImpl
+
+    @staticmethod
+    def get_builder_cls() -> type[DMSFlashAttentionMetadataBuilder]:
+        return DMSFlashAttentionMetadataBuilder
+
+    @staticmethod
+    def get_kv_cache_shape(
+        num_blocks: int,
+        block_size: int,
+        num_kv_heads: int,
+        head_size: int,
+        cache_dtype_str: str = "auto",
+    ) -> tuple[int, ...]:
+        if block_size % 16 != 0:
+            raise ValueError("Block size must be a multiple of 16.")
+        return (2, num_blocks, block_size, num_kv_heads, head_size)
+
+    @staticmethod
+    def get_kv_cache_stride_order(
+        include_num_layers_dimension: bool = False,
+    ) -> tuple[int, ...]:
+        from vllm.v1.attention.backends.utils import get_kv_cache_layout
+
+        cache_layout = get_kv_cache_layout()
+        if cache_layout == "NHD" and include_num_layers_dimension:
+            return (2, 0, 1, 3, 4, 5)
+        elif cache_layout == "NHD":
+            return (0, 1, 2, 3, 4)
+        elif cache_layout == "HND" and include_num_layers_dimension:
+            return (2, 4, 0, 1, 3, 5)
+        elif cache_layout == "HND":
+            return (0, 1, 3, 2, 4)
+        else:
+            raise ValueError(f"Unknown cache layout format {cache_layout}.")
+
+    @classmethod
+    def supports_head_size(cls, head_size: int) -> bool:
+        return head_size % 8 == 0 and head_size <= 256
+
+    @classmethod
+    def supports_kv_cache_dtype(cls, kv_cache_dtype: str | None) -> bool:
+        if kv_cache_dtype is None:
+            return True
+        if kv_cache_dtype.startswith("fp8"):
+            return flash_attn_supports_fp8()
+        return kv_cache_dtype in ["auto", "bfloat16"]
+
+    @classmethod
+    def supports_compute_capability(cls, capability) -> bool:
+        from vllm.platforms.interface import DeviceCapability
+
+        return capability >= DeviceCapability(8, 0)
+
+
+@dataclass
+class DMSFlashAttentionMetadata:
+    """Attention metadata for DMS backend."""
+
+    num_actual_tokens: int
+    max_query_len: int
+    query_start_loc: torch.Tensor
+    max_seq_len: int
+    seq_lens: torch.Tensor
+    block_table: torch.Tensor
+    slot_mapping: torch.Tensor
+    causal: bool = True
+
+    # For cascade attention compatibility (not used with DMS).
+    use_cascade: bool = False
+    common_prefix_len: int = 0
+    cu_prefix_query_lens: torch.Tensor | None = None
+    prefix_kv_lens: torch.Tensor | None = None
+    suffix_kv_lens: torch.Tensor | None = None
+
+    scheduler_metadata: torch.Tensor | None = None
+    prefix_scheduler_metadata: torch.Tensor | None = None
+    max_num_splits: int = 0
+
+
+class DMSFlashAttentionMetadataBuilder(
+    AttentionMetadataBuilder[DMSFlashAttentionMetadata]
+):
+    """Builds DMS attention metadata from common metadata.
+
+    Produces standard per-request metadata. The per-head block tables
+    and seq_lens are computed at runtime in the impl from DMSState.
+    """
+
+    _cudagraph_support = AttentionCGSupport.NEVER
+    supports_update_block_table: bool = True
+
+    @classmethod
+    def get_cudagraph_support(
+        cls,
+        vllm_config: VllmConfig,
+        kv_cache_spec: AttentionSpec,
+    ) -> AttentionCGSupport:
+        return cls._cudagraph_support
+
+    def __init__(
+        self,
+        kv_cache_spec: AttentionSpec,
+        layer_names: list[str],
+        vllm_config: VllmConfig,
+        device: torch.device,
+    ):
+        super().__init__(kv_cache_spec, layer_names, vllm_config, device)
+        self.model_config = vllm_config.model_config
+        self.cache_config = vllm_config.cache_config
+        self.num_heads_kv = self.model_config.get_num_kv_heads(
+            vllm_config.parallel_config
+        )
+        self.block_size = kv_cache_spec.block_size
+
+    def build(
+        self,
+        common_prefix_len: int,
+        common_attn_metadata: CommonAttentionMetadata,
+        fast_build: bool = False,
+    ) -> DMSFlashAttentionMetadata:
+        return DMSFlashAttentionMetadata(
+            num_actual_tokens=common_attn_metadata.num_actual_tokens,
+            max_query_len=common_attn_metadata.max_query_len,
+            query_start_loc=common_attn_metadata.query_start_loc,
+            max_seq_len=common_attn_metadata.max_seq_len,
+            seq_lens=common_attn_metadata.seq_lens,
+            block_table=common_attn_metadata.block_table_tensor,
+            slot_mapping=common_attn_metadata.slot_mapping,
+            causal=common_attn_metadata.causal,
+        )
+
+    def update_block_table(
+        self,
+        metadata: DMSFlashAttentionMetadata,
+        blk_table: torch.Tensor,
+        slot_mapping: torch.Tensor,
+    ) -> DMSFlashAttentionMetadata:
+        new_metadata = copy.copy(metadata)
+        new_metadata.block_table = blk_table
+        new_metadata.slot_mapping = slot_mapping
+        return new_metadata
+
+    def use_cascade_attention(self, *args, **kwargs) -> bool:
+        return False
+
+
+class DMSFlashAttentionImpl(AttentionImpl):
+    """DMS FlashAttention implementation with per-head eviction.
+
+    Each impl instance corresponds to one Attention layer and holds
+    its own DMSState (created lazily on first decode step).
+
+    Key integration points:
+    - do_kv_cache_update(): Per-head cache writes + DMSState update
+    - forward(): Per-head decode via batch×head flattening
+    """
+
+    can_return_lse_for_decode: bool = False
+
+    def __init__(
+        self,
+        num_heads: int,
+        head_size: int,
+        scale: float,
+        num_kv_heads: int,
+        alibi_slopes: list[float] | None,
+        sliding_window: int | None,
+        kv_cache_dtype: str,
+        logits_soft_cap: float | None = None,
+        attn_type: AttentionType = AttentionType.DECODER,
+        kv_sharing_target_layer_name: str | None = None,
+        sinks: torch.Tensor | None = None,
+    ) -> None:
+        self.num_heads = num_heads
+        self.head_size = head_size
+        self.scale = float(scale)
+        self.num_kv_heads = num_kv_heads
+        self.num_queries_per_kv = num_heads // num_kv_heads
+        if alibi_slopes is not None:
+            alibi_slopes = torch.tensor(alibi_slopes, dtype=torch.float32)
+        self.alibi_slopes = alibi_slopes
+        if sliding_window is None:
+            self.sliding_window = (-1, -1)
+        else:
+            self.sliding_window = (sliding_window - 1, 0)
+        self.kv_cache_dtype = kv_cache_dtype
+        if logits_soft_cap is None:
+            logits_soft_cap = 0
+        self.logits_soft_cap = logits_soft_cap
+        self.kv_sharing_target_layer_name = kv_sharing_target_layer_name
+        self.attn_type = attn_type
+
+        self.vllm_flash_attn_version = get_flash_attn_version(
+            requires_alibi=alibi_slopes is not None,
+            head_size=head_size,
+        )
+
+        if is_quantized_kv_cache(self.kv_cache_dtype) and not flash_attn_supports_fp8():
+            raise NotImplementedError(
+                "FlashAttention does not support fp8 kv-cache on this device."
+            )
+
+        # --- DMS state (per-layer, lazy init) ---
+        self._dms_state: DMSState | None = None
+        self._dms_config: DMSConfig | None = None
+        # Decisions from the PREVIOUS step, used by do_kv_cache_update
+        # to update DMSState before writing the new token.
+        self._prev_decisions: torch.Tensor | None = None
+        # Cache positions written in the current step (for DMSState update).
+        self._current_write_positions: torch.Tensor | None = None
+
+    def _get_dms_config(self) -> DMSConfig | None:
+        """Lazily fetch DMSConfig from VllmConfig."""
+        if self._dms_config is None:
+            try:
+                vllm_config = get_current_vllm_config()
+                self._dms_config = vllm_config.cache_config.dms_config
+            except Exception:
+                pass
+        return self._dms_config
+
+    def _get_or_create_dms_state(
+        self,
+        batch_size: int,
+        max_seq_len: int,
+        block_size: int,
+        device: torch.device,
+    ) -> DMSState | None:
+        """Get or create DMSState for this layer."""
+        dms_config = self._get_dms_config()
+        if dms_config is None:
+            return None
+
+        if self._dms_state is None or self._dms_state.batch_size < batch_size:
+            self._dms_state = DMSState(
+                dms_config=dms_config,
+                batch_size=batch_size,
+                num_kv_heads=self.num_kv_heads,
+                max_seq_len=max_seq_len,
+                block_size=block_size,
+                device=device,
+            )
+        return self._dms_state
+
+    def _get_layer_decisions(self, layer_name: str) -> torch.Tensor | None:
+        """Read DMS decisions from ForwardContext for this layer."""
+        try:
+            ctx = get_forward_context()
+            decisions_dict = ctx.additional_kwargs.get(DMS_DECISIONS_KEY)
+            if decisions_dict is not None:
+                return decisions_dict.get(layer_name)
+        except (AssertionError, AttributeError):
+            pass
+        return None
+
+    def forward(
+        self,
+        layer: torch.nn.Module,
+        query: torch.Tensor,
+        key: torch.Tensor,
+        value: torch.Tensor,
+        kv_cache: torch.Tensor,
+        attn_metadata: DMSFlashAttentionMetadata,
+        output: torch.Tensor | None = None,
+        output_scale: torch.Tensor | None = None,
+        output_block_scale: torch.Tensor | None = None,
+    ) -> torch.Tensor:
+        """Forward pass with DMS-aware FlashAttention."""
+        assert output is not None, "Output tensor must be provided."
+
+        if attn_metadata is None:
+            return output.fill_(0)
+
+        num_actual_tokens = attn_metadata.num_actual_tokens
+        key_cache, value_cache = kv_cache.unbind(0)
+
+        if self.kv_cache_dtype.startswith("fp8"):
+            dtype = DMSFlashAttentionBackend.get_fp8_dtype_for_flashattn(
+                self.kv_cache_dtype
+            )
+            key_cache = key_cache.view(dtype)
+            value_cache = value_cache.view(dtype)
+
+        is_decode = attn_metadata.max_query_len == 1
+
+        if is_decode and self._dms_state is not None:
+            dms_state = self._dms_state
+            num_reqs = attn_metadata.query_start_loc.shape[0] - 1
+
+            # Build per-head seq_lens and block_table from DMSState.
+            per_head_seq_lens = dms_state.cache_seq_lens[
+                : num_reqs * self.num_kv_heads
+            ]
+            # Per-head block_table: repeat each request's row for each head.
+            # block_table shape: (num_reqs, max_blocks)
+            # → (num_reqs * num_kv_heads, max_blocks)
+            per_head_block_table = attn_metadata.block_table[:num_reqs].repeat_interleave(
+                self.num_kv_heads, dim=0
+            )
+
+            return self._forward_decode_per_head(
+                query[:num_actual_tokens],
+                key_cache,
+                value_cache,
+                output[:num_actual_tokens],
+                per_head_seq_lens,
+                per_head_block_table,
+                layer,
+            )
+
+        # Standard prefill or decode without DMS state.
+        cu_seqlens_q = attn_metadata.query_start_loc
+        seqused_k = attn_metadata.seq_lens
+        max_seqlen_q = attn_metadata.max_query_len
+        max_seqlen_k = attn_metadata.max_seq_len
+        block_table = attn_metadata.block_table
+
+        num_reqs = cu_seqlens_q.shape[0] - 1
+        descale_shape = (num_reqs, self.num_kv_heads)
+        q_descale = layer._q_scale.expand(descale_shape)
+        k_descale = layer._k_scale.expand(descale_shape)
+        v_descale = layer._v_scale.expand(descale_shape)
+
+        flash_attn_varlen_func(
+            q=query[:num_actual_tokens],
+            k=key_cache,
+            v=value_cache,
+            out=output[:num_actual_tokens],
+            cu_seqlens_q=cu_seqlens_q,
+            max_seqlen_q=max_seqlen_q,
+            seqused_k=seqused_k,
+            max_seqlen_k=max_seqlen_k,
+            softmax_scale=self.scale,
+            causal=attn_metadata.causal,
+            alibi_slopes=self.alibi_slopes,
+            window_size=list(self.sliding_window),
+            block_table=block_table,
+            softcap=self.logits_soft_cap,
+            fa_version=self.vllm_flash_attn_version,
+            q_descale=q_descale,
+            k_descale=k_descale,
+            v_descale=v_descale,
+            num_splits=attn_metadata.max_num_splits,
+        )
+
+        # After prefill: compact KV cache and initialize DMSState.
+        if not is_decode:
+            max_seq_len = int(attn_metadata.max_seq_len)
+            # Infer block_size from cache shape
+            cache_block_size = key_cache.shape[1]  # block_size dim
+            dms_state = self._get_or_create_dms_state(
+                batch_size=num_reqs,
+                max_seq_len=max(max_seq_len, 4096),
+                block_size=cache_block_size,
+                device=query.device,
+            )
+            if dms_state is not None:
+                # Try to get this layer's decisions for compaction.
+                layer_name = getattr(layer, "layer_name", None)
+                decisions = None
+                if layer_name is not None:
+                    decisions = self._get_layer_decisions(layer_name)
+
+                if decisions is not None:
+                    self._compact_prefill(
+                        dms_state, decisions, kv_cache,
+                        attn_metadata, num_reqs, cache_block_size,
+                    )
+                else:
+                    # No decisions available — initialize seq_lens
+                    # uniformly (all heads same length, no compaction).
+                    for req_idx in range(num_reqs):
+                        sl = attn_metadata.seq_lens[req_idx]
+                        start = req_idx * self.num_kv_heads
+                        end = start + self.num_kv_heads
+                        dms_state.cache_seq_lens[start:end] = sl
+                        dms_state.tokens_seen[start:end] = sl
+
+        return output
+
+    def _compact_prefill(
+        self,
+        dms_state: DMSState,
+        decisions: torch.Tensor,
+        kv_cache: torch.Tensor,
+        attn_metadata: DMSFlashAttentionMetadata,
+        num_reqs: int,
+        block_size: int,
+    ) -> None:
+        """Compact KV cache after prefill using DMS eviction decisions.
+
+        For each request:
+        1. Compute which tokens survive per head (shift-by-one + window).
+        2. Compact KV pairs in-place so survivors are contiguous.
+        3. Initialize DMSState circular buffer for seamless decode.
+        """
+        from vllm.v1.attention.dms.dms_prefill import (
+            compact_kv_cache,
+            compute_prefill_survivors,
+            initialize_dms_state_from_prefill,
+        )
+
+        token_offset = 0
+        for req_idx in range(num_reqs):
+            sl = int(attn_metadata.seq_lens[req_idx].item())
+            req_decisions = decisions[token_offset:token_offset + sl]
+
+            survivors = compute_prefill_survivors(
+                req_decisions, sl, dms_state.window_size,
+            )
+
+            req_block_table = attn_metadata.block_table[req_idx]
+
+            per_head_seq_lens, _ = compact_kv_cache(
+                kv_cache, survivors, sl, block_size, req_block_table,
+            )
+
+            initialize_dms_state_from_prefill(
+                dms_state, req_decisions, survivors,
+                per_head_seq_lens, req_idx, sl,
+            )
+
+            token_offset += sl
+
+    def _forward_decode_per_head(
+        self,
+        query: torch.Tensor,
+        key_cache: torch.Tensor,
+        value_cache: torch.Tensor,
+        output: torch.Tensor,
+        per_head_seq_lens: torch.Tensor,
+        per_head_block_table: torch.Tensor,
+        layer: torch.nn.Module,
+    ) -> torch.Tensor:
+        """Decode with per-head block tables via batch×head flattening.
+
+        Reshapes Q from (batch, num_q_heads, head_dim) to
+        (batch * num_kv_heads, q_per_kv, head_dim) and calls
+        flash_attn_varlen_func with per-head block_table/seq_lens.
+        """
+        batch_size = query.shape[0]
+        q_per_kv = self.num_queries_per_kv
+        page_batch = batch_size * self.num_kv_heads
+
+        # Reshape Q: (batch, num_q_heads, head_dim)
+        #          → (batch * num_kv_heads, q_per_kv, head_dim)
+        q_reshaped = query.view(
+            batch_size, self.num_kv_heads, q_per_kv, self.head_size
+        ).reshape(page_batch, q_per_kv, self.head_size)
+
+        cu_seqlens_q = torch.arange(
+            0,
+            (page_batch + 1) * q_per_kv,
+            q_per_kv,
+            dtype=torch.int32,
+            device=query.device,
+        )
+
+        max_seq_len_k = (
+            int(per_head_seq_lens.max().item()) if page_batch > 0 else 0
+        )
+
+        descale_shape = (page_batch, 1)
+        q_descale = layer._q_scale.expand(descale_shape)
+        k_descale = layer._k_scale.expand(descale_shape)
+        v_descale = layer._v_scale.expand(descale_shape)
+
+        out_flat = torch.empty(
+            page_batch * q_per_kv,
+            self.head_size,
+            dtype=query.dtype,
+            device=query.device,
+        )
+
+        flash_attn_varlen_func(
+            q=q_reshaped.reshape(page_batch * q_per_kv, self.head_size),
+            k=key_cache,
+            v=value_cache,
+            out=out_flat,
+            cu_seqlens_q=cu_seqlens_q,
+            max_seqlen_q=q_per_kv,
+            seqused_k=per_head_seq_lens,
+            max_seqlen_k=max_seq_len_k,
+            softmax_scale=self.scale,
+            causal=True,
+            alibi_slopes=self.alibi_slopes,
+            window_size=list(self.sliding_window),
+            block_table=per_head_block_table,
+            softcap=self.logits_soft_cap,
+            fa_version=self.vllm_flash_attn_version,
+            q_descale=q_descale,
+            k_descale=k_descale,
+            v_descale=v_descale,
+        )
+
+        # Reshape back: (batch * num_kv_heads * q_per_kv, head_dim)
+        #             → (batch, num_q_heads, head_dim)
+        output_reshaped = out_flat.view(
+            batch_size, self.num_kv_heads, q_per_kv, self.head_size
+        ).reshape(batch_size, self.num_heads, self.head_size)
+
+        output[:batch_size].copy_(output_reshaped)
+        return output
+
+    def do_kv_cache_update(
+        self,
+        layer: torch.nn.Module,
+        key: torch.Tensor,
+        value: torch.Tensor,
+        kv_cache: torch.Tensor,
+        slot_mapping: torch.Tensor,
+    ) -> None:
+        """Update KV cache with DMS-aware per-head slot management.
+
+        Flow:
+        1. Read current decisions from ForwardContext (the model layer
+           has already extracted and stored them before calling attn).
+        2. If DMSState exists (decode after first prefill):
+           a. Determine per-head write positions from DMSState
+              (reuse evicted slot or append).
+           b. Write K/V per-head using direct tensor indexing.
+           c. Update DMSState circular buffer with current decisions.
+        3. If no DMSState (prefill): standard reshape_and_cache.
+        """
+        key_cache, value_cache = kv_cache.unbind(0)
+
+        # Get this layer's name to look up its decisions.
+        layer_name = getattr(layer, "layer_name", None)
+
+        # Try to get decisions from ForwardContext.
+        decisions = None
+        if layer_name is not None:
+            decisions = self._get_layer_decisions(layer_name)
+
+        dms_state = self._dms_state
+        num_tokens = slot_mapping.shape[0]
+
+        # Check if this is a decode step with active DMS state.
+        if dms_state is not None and decisions is not None and num_tokens > 0:
+            # --- Per-head decode cache write ---
+            # decisions shape: (num_tokens, num_kv_heads)
+            num_reqs = num_tokens  # For decode, 1 token per request.
+
+            # Determine per-head write positions.
+            # For each (req, head): either reuse an evicted slot or append.
+            req_indices = torch.arange(
+                num_reqs, device=key.device, dtype=torch.long
+            )
+
+            # Get per-head cache positions to write to.
+            # Shape: (num_reqs, num_kv_heads)
+            write_positions = dms_state.get_decode_slot_mapping(req_indices)
+
+            # Convert cache positions to physical cache slots.
+            # cache_position → (block_idx, offset_in_block)
+            # block_id = block_table[req, block_idx]
+            # slot = block_id * block_size + offset
+            block_size = key_cache.shape[1]  # (num_blocks, block_size, ...)
+
+            try:
+                # Get block_table from ForwardContext metadata.
+                ctx = get_forward_context()
+                attn_metadata = ctx.attn_metadata
+                if isinstance(attn_metadata, dict):
+                    # Find this layer's metadata
+                    md = attn_metadata.get(layer_name)
+                    if md is not None:
+                        block_table = md.block_table
+                    else:
+                        # Fallback: use first available
+                        block_table = next(iter(attn_metadata.values())).block_table
+                else:
+                    block_table = attn_metadata.block_table
+            except (AssertionError, AttributeError, StopIteration):
+                # Can't get block table, fall back to standard write.
+                reshape_and_cache_flash(
+                    key, value, key_cache, value_cache, slot_mapping,
+                    self.kv_cache_dtype, layer._k_scale, layer._v_scale,
+                )
+                return
+
+            # Write K/V per-head using direct tensor indexing.
+            # key shape: (num_tokens, num_kv_heads, head_dim)
+            # For each req r and head h:
+            #   pos = write_positions[r, h]
+            #   block_idx = pos // block_size
+            #   offset = pos % block_size
+            #   block_id = block_table[r, block_idx]
+            #   key_cache[block_id, offset, h, :] = key[r, h, :]
+            block_indices = write_positions // block_size
+            offsets = write_positions % block_size
+
+            # Look up physical block IDs from block_table.
+            # block_table: (num_reqs, max_blocks)
+            # block_indices: (num_reqs, num_kv_heads) — may differ per head.
+            # We need block_table[r, block_indices[r, h]] for each (r, h).
+            req_expand = req_indices.unsqueeze(1).expand_as(block_indices)
+            block_ids = block_table[req_expand, block_indices]
+            # block_ids: (num_reqs, num_kv_heads)
+
+            head_arange = torch.arange(
+                self.num_kv_heads, device=key.device
+            ).unsqueeze(0).expand(num_reqs, -1)
+
+            # Write keys and values per-head.
+            # key[:num_tokens] shape: (num_tokens, num_kv_heads, head_dim)
+            key_cache[block_ids, offsets, head_arange] = key[
+                :num_tokens, :self.num_kv_heads, :
+            ]
+            value_cache[block_ids, offsets, head_arange] = value[
+                :num_tokens, :self.num_kv_heads, :
+            ]
+
+            # Update DMSState with current decisions and write positions.
+            dms_state.update_decode(decisions, write_positions)
+
+        else:
+            # Standard cache write (prefill or no DMS state yet).
+            reshape_and_cache_flash(
+                key,
+                value,
+                key_cache,
+                value_cache,
+                slot_mapping,
+                self.kv_cache_dtype,
+                layer._k_scale,
+                layer._v_scale,
+            )
