+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Benchmark: DMS Triton decode kernel vs baseline (no DMS).
+
+Usage:
+    python tests/v1/attention/bench_dms_decode.py kernel   # Part 1 only
+    python tests/v1/attention/bench_dms_decode.py dms_on   # Part 2a: DMS enabled
+    python tests/v1/attention/bench_dms_decode.py dms_off  # Part 2b: DMS disabled
+    python tests/v1/attention/bench_dms_decode.py all      # Run all sequentially (subprocess)
+"""
+
+import os
+import sys
+import time
+
+os.environ["VLLM_ENABLE_V1_MULTIPROCESSING"] = "0"
+
+import torch
+
+
+MODEL_PATH = os.path.normpath(os.path.join(
+    os.path.dirname(os.path.abspath(__file__)),
+    "..", "..", "..", "models", "Qwen3-8B-DMS-8x-4bit-NF4",
+))
+
+PROMPT = "Explain the theory of general relativity in detail, covering"
+MAX_TOKENS = 256
+
+
+def bench_triton_kernel():
+    """Microbenchmark the Triton DMS decode kernel in isolation."""
+    from vllm.v1.attention.dms.triton_dms_decode import dms_paged_decode_attention
+
+    print("=" * 60)
+    print("PART 1: Triton kernel microbenchmark")
+    print("=" * 60)
+
+    num_reqs = 1
+    num_kv_heads = 8
+    num_q_heads = 32
+    head_size = 128
+    block_size = 16
+    scale = 1.0 / (head_size ** 0.5)
+
+    for seq_len in [64, 256, 512, 1024]:
+        num_blocks = (seq_len + block_size - 1) // block_size
+
+        q = torch.randn(num_reqs, num_q_heads, head_size,
+                         dtype=torch.bfloat16, device="cuda") * 0.1
+        kc = torch.randn(num_blocks + 10, block_size, num_kv_heads, head_size,
+                          dtype=torch.bfloat16, device="cuda") * 0.1
+        vc = torch.randn_like(kc)
+        bt = torch.arange(num_blocks, dtype=torch.int32, device="cuda").unsqueeze(0)
+        sl = torch.full((num_kv_heads,), seq_len, dtype=torch.int32, device="cuda")
+        out = torch.zeros_like(q)
+
+        # Warmup (includes Triton compilation).
+        for _ in range(5):
+            dms_paged_decode_attention(q, kc, vc, out, bt, sl,
+                                       num_kv_heads, num_q_heads, head_size, scale)
+        torch.cuda.synchronize()
+
+        N = 200
+        start = time.perf_counter()
+        for _ in range(N):
+            dms_paged_decode_attention(q, kc, vc, out, bt, sl,
+                                       num_kv_heads, num_q_heads, head_size, scale)
+        torch.cuda.synchronize()
+        elapsed = time.perf_counter() - start
+
+        ms_per_call = elapsed / N * 1000
+        ms_per_step = ms_per_call * 36  # 36 layers
+        print(f"  seq_len={seq_len:5d}: {ms_per_call:.3f} ms/call, "
+              f"x36 layers = {ms_per_step:.1f} ms/step, "
+              f"attn-only tok/s = {1000 / ms_per_step:.0f}")
+
+    print()
+
+
+def bench_e2e(dms_enabled: bool):
+    """End-to-end generation benchmark."""
+    from vllm import LLM, SamplingParams
+
+    label = "DMS ON" if dms_enabled else "DMS OFF"
+    print("=" * 60)
+    print(f"PART 2: End-to-end generation [{label}]")
+    print("=" * 60)
+
+    print(f"\n[{label}] Loading model...")
+    llm = LLM(
+        model=MODEL_PATH,
+        quantization="bitsandbytes",
+        load_format="bitsandbytes",
+        max_model_len=2048,
+        gpu_memory_utilization=0.85,
+        enforce_eager=True,
+    )
+
+    if not dms_enabled:
+        # Disable DMS on all attention layers so decode uses
+        # the standard flash_attn path (no per-head logic).
+        from vllm.v1.attention.backends.dms_flash_attn import DMSFlashAttentionImpl
+        for impl in DMSFlashAttentionImpl._all_instances:
+            impl._dms_config = None
+            impl._dms_state = None
+
+    sampling = SamplingParams(
+        max_tokens=MAX_TOKENS,
+        temperature=0.7,
+        top_p=0.9,
+    )
+
+    # Warmup
+    llm.generate(["Hello"], SamplingParams(max_tokens=8))
+
+    start = time.perf_counter()
+    outputs = llm.generate([PROMPT], sampling)
+    elapsed = time.perf_counter() - start
+
+    gen_tokens = len(outputs[0].outputs[0].token_ids)
+    prompt_tokens = len(outputs[0].prompt_token_ids)
+    toks_per_sec = gen_tokens / elapsed
+
+    print(f"\n[{label}] {gen_tokens} tokens in {elapsed:.1f}s "
+          f"= {toks_per_sec:.1f} tok/s "
+          f"(prompt={prompt_tokens} tokens)")
+    print()
+
+
+def run_all():
+    """Run all benchmarks as separate subprocesses to avoid GPU memory issues."""
+    import subprocess
+
+    script = os.path.abspath(__file__)
+    python = sys.executable
+
+    for mode in ["kernel", "dms_on", "dms_off"]:
+        print(f"\n{'#' * 60}")
+        print(f"# Running: {mode}")
+        print(f"{'#' * 60}\n")
+        result = subprocess.run(
+            [python, script, mode],
+            env={**os.environ, "VLLM_ENABLE_V1_MULTIPROCESSING": "0"},
+        )
+        if result.returncode != 0:
+            print(f"WARNING: {mode} exited with code {result.returncode}")
+
+
+if __name__ == "__main__":
+    mode = sys.argv[1] if len(sys.argv) > 1 else "all"
+
+    if mode == "kernel":
+        bench_triton_kernel()
+    elif mode == "dms_on":
+        bench_e2e(dms_enabled=True)
+    elif mode == "dms_off":
+        bench_e2e(dms_enabled=False)
+    elif mode == "all":
+        run_all()
+    else:
+        print(f"Unknown mode: {mode}")
+        print("Usage: bench_dms_decode.py [kernel|dms_on|dms_off|all]")
+        sys.exit(1)
