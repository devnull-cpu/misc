+    def _collect_dms_effective_tokens(
+        self,
+        req_ids: list[str],
+    ) -> dict[str, int] | None:
+        """Collect effective cache token counts from DMS state.
+
+        For each active request, reports the max per-head cache_seq_len
+        across all layers. The scheduler uses this to avoid over-allocating
+        blocks for DMS requests where eviction keeps cache length bounded.
+
+        Returns None if DMS is not active (no instances registered).
+        """
+        from vllm.v1.attention.backends.dms_flash_attn import (
+            DMSFlashAttentionImpl,
+        )
+
+        if not DMSFlashAttentionImpl._all_instances:
+            return None
+
+        # Use the first layer's DMSState as representative —
+        # all layers have the same num_kv_heads and batch mapping.
+        first_impl = DMSFlashAttentionImpl._all_instances[0]
+        dms_state = first_impl._dms_state
+        if dms_state is None:
+            return None
+
+        num_kv_heads = first_impl.num_kv_heads
+        result: dict[str, int] = {}
+
+        for req_id in req_ids:
+            # Get the request index from input_batch.
+            req_idx = self.input_batch.req_id_to_index.get(req_id)
+            if req_idx is None:
+                continue
+            # Max per-head seq_len for this request.
+            start = req_idx * num_kv_heads
+            end = start + num_kv_heads
+            max_seq_len = int(dms_state.cache_seq_lens[start:end].max().item())
+            if max_seq_len > 0:
+                result[req_id] = max_seq_len
+
+        return result if result else None
