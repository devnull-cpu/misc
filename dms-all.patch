+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Two-pass DMS prefill compaction (Phase 1).
+
+After a standard prefill writes all tokens to the KV cache,
+this module compacts the cache by:
+1. Extracting all eviction decisions from the prefill pass.
+2. Applying the shift-by-one rule (decision for token t applies to t-1).
+3. Per head: determining survivor tokens, compacting KV pairs into
+   per-head block tables, and updating per-head seq_lens.
+
+Phase 3 will replace this with a fused FlexAttention or Triton kernel
+for single-pass prefill with DMS masking.
+
+Reference: Model Optimizer attention_prefill.py,
+           kvcompress triton_kernels.py dms_fused_prefill.
+"""
+
+from __future__ import annotations
+
+import torch
+
+from vllm.config.dms import DMSConfig
+from vllm.v1.attention.dms.dms_state import DMSState
+
+
+def compute_prefill_survivors(
+    decisions: torch.Tensor,
+    seq_len: int,
+    window_size: int,
+) -> torch.Tensor:
+    """Compute which tokens survive DMS eviction after prefill.
+
+    Implements the shift-by-one delayed eviction rule:
+    - Decision for token t is made by token t+1.
+    - A token marked for eviction survives for `window_size` steps.
+    - Tokens in the trailing window always survive.
+
+    Args:
+        decisions: Binary eviction decisions from the model,
+            shape ``(seq_len, num_kv_heads)``. 1 = evict, 0 = keep.
+        seq_len: Number of tokens in the sequence.
+        window_size: DMS delayed eviction window size.
+
+    Returns:
+        survivors: Boolean mask, shape ``(seq_len, num_kv_heads)``.
+            True = token survives in the compressed cache.
+    """
+    num_kv_heads = decisions.shape[1]
+    device = decisions.device
+
+    # Shift-by-one: decision[t] applies to token t-1.
+    # Pad with 0 (keep) at the beginning, drop the last.
+    shifted = torch.zeros_like(decisions)
+    if seq_len > 1:
+        shifted[:-1] = decisions[1:]
+    # The last token's decision doesn't evict anything (no token after it yet).
+
+    # A token is evicted if:
+    # 1. It was marked for eviction (shifted decision == 1), AND
+    # 2. It's outside the trailing window (position < seq_len - window_size).
+    positions = torch.arange(seq_len, device=device).unsqueeze(1).expand(
+        -1, num_kv_heads
+    )
+    in_window = positions >= (seq_len - window_size)
+
+    # Tokens survive if: they were NOT marked for eviction, OR they're
+    # in the trailing window.
+    survivors = (shifted == 0) | in_window
+
+    return survivors
+
+
+def compact_kv_cache(
+    kv_cache: torch.Tensor,
+    survivors: torch.Tensor,
+    seq_len: int,
+    block_size: int,
+    original_block_table: torch.Tensor,
+) -> tuple[torch.Tensor, torch.Tensor]:
+    """Compact KV cache entries based on survivor mask.
+
+    Copies surviving KV pairs into contiguous positions per head,
+    updating the effective sequence length for each head.
+
+    Args:
+        kv_cache: KV cache tensor, shape
+            ``(2, num_blocks, block_size, num_kv_heads, head_size)``.
+        survivors: Boolean mask, shape ``(seq_len, num_kv_heads)``.
+        seq_len: Original sequence length.
+        block_size: Cache block size.
+        original_block_table: Block table for this request,
+            shape ``(max_blocks,)``.
+
+    Returns:
+        per_head_seq_lens: Actual sequence length per head after
+            compaction, shape ``(num_kv_heads,)``.
+        compacted: Whether compaction was performed (always True
+            if any eviction occurred).
+    """
+    num_kv_heads = survivors.shape[1]
+    device = kv_cache.device
+    key_cache, value_cache = kv_cache[0], kv_cache[1]
+
+    per_head_seq_lens = torch.zeros(
+        num_kv_heads, dtype=torch.int32, device=device
+    )
+
+    for head_idx in range(num_kv_heads):
+        head_survivors = survivors[:, head_idx]
+        survivor_indices = head_survivors.nonzero(as_tuple=True)[0]
+        num_survivors = survivor_indices.shape[0]
+        per_head_seq_lens[head_idx] = num_survivors
+
+        if num_survivors == seq_len:
+            # No eviction for this head, nothing to compact.
+            continue
+
+        # Read surviving KV pairs and write them back to contiguous
+        # positions. We read from the original positions and write
+        # to positions 0..num_survivors-1.
+        for dst_pos, src_pos_tensor in enumerate(survivor_indices):
+            src_pos = src_pos_tensor.item()
+            if dst_pos == src_pos:
+                # Already in the right place.
+                continue
+
+            # Compute source block and offset.
+            src_block_idx = src_pos // block_size
+            src_offset = src_pos % block_size
+            src_block_id = original_block_table[src_block_idx].item()
+
+            # Compute destination block and offset.
+            dst_block_idx = dst_pos // block_size
+            dst_offset = dst_pos % block_size
+            dst_block_id = original_block_table[dst_block_idx].item()
+
+            # Copy key and value for this head.
+            key_cache[dst_block_id, dst_offset, head_idx] = (
+                key_cache[src_block_id, src_offset, head_idx].clone()
+            )
+            value_cache[dst_block_id, dst_offset, head_idx] = (
+                value_cache[src_block_id, src_offset, head_idx].clone()
+            )
+
+    return per_head_seq_lens, True
+
+
+def initialize_dms_state_from_prefill(
+    dms_state: DMSState,
+    decisions: torch.Tensor,
+    survivors: torch.Tensor,
+    per_head_seq_lens: torch.Tensor,
+    req_idx: int,
+    seq_len: int,
+) -> None:
+    """Initialize DMSState circular buffer from prefill decisions.
+
+    Fills the circular buffer with the trailing `window_size` tokens'
+    decisions and positions, so decode can continue seamlessly.
+
+    Args:
+        dms_state: The DMSState to initialize.
+        decisions: Binary decisions from prefill, shape ``(seq_len, num_kv_heads)``.
+        survivors: Survivor mask, shape ``(seq_len, num_kv_heads)``.
+        per_head_seq_lens: Compacted seq lengths, shape ``(num_kv_heads,)``.
+        req_idx: Request index in the batch.
+        seq_len: Original sequence length.
+    """
+    window_size = dms_state.window_size
+    num_kv_heads = dms_state.num_kv_heads
+
+    # Fill the circular buffer with the last `window_size` tokens.
+    window_start = max(0, seq_len - window_size)
+    window_len = seq_len - window_start
+
+    for head_idx in range(num_kv_heads):
+        page_idx = req_idx * num_kv_heads + head_idx
+
+        # Set cache seq len.
+        dms_state.cache_seq_lens[page_idx] = per_head_seq_lens[head_idx]
+
+        # Compute the cache positions of the trailing window tokens.
+        # These are the compacted positions of the survivors.
+        head_survivors = survivors[:, head_idx]
+        survivor_positions = head_survivors.nonzero(as_tuple=True)[0]
+
+        for i in range(window_len):
+            token_pos = window_start + i
+            buf_idx = i % window_size
+
+            # Find the compacted cache position of this token.
+            # Since survivor_positions is sorted, we can binary search.
+            cache_pos_mask = survivor_positions == token_pos
+            if cache_pos_mask.any():
+                cache_pos = cache_pos_mask.nonzero(as_tuple=True)[0][0].item()
+            else:
+                cache_pos = -1  # Was evicted
+
+            # Shift-by-one: decision[t] was made by token t+1.
+            if token_pos + 1 < seq_len:
+                evict_flag = decisions[token_pos + 1, head_idx].item()
+            else:
+                evict_flag = 0  # No decision yet for the last token
+
+            dms_state.recent_info[page_idx, buf_idx, 0] = cache_pos
+            dms_state.recent_info[page_idx, buf_idx, 1] = int(evict_flag)
+
+        # Set circular pointer to the next write position.
+        dms_state.circular_ptr[page_idx] = window_len % window_size
+        dms_state.tokens_seen[page_idx] = seq_len
diff --git a/vllm/v1/attention/dms/dms_state.py b/vllm/v1/attention/dms/dms_state.py
new file mode 100644
