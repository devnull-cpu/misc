+        req_blocks = self.req_to_blocks.get(request_id)
+        if not req_blocks:
+            return []
+
+        replacements: list[tuple[int, int]] = []
+        for i, block in enumerate(req_blocks):
+            if block.is_null or block.ref_cnt <= 1:
+                continue
+            # Allocate a fresh private block.
+            new_block = self.block_pool.get_new_blocks(1)[0]
+            old_block = block
+
+            # This request no longer references the shared block.
+            old_block.ref_cnt -= 1
+            if old_block.ref_cnt == 0:
+                self.block_pool.free_block_queue.append_n([old_block])
+
+            # new_block already has ref_cnt == 1 from get_new_blocks().
+            req_blocks[i] = new_block
+            replacements.append((old_block.block_id, new_block.block_id))
+
+        return replacements
