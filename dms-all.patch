+
+    Returns:
+        per_head_seq_lens: ``(num_kv_heads,)`` int32.
+    """
+    num_kv_heads = survivors.shape[1]
+    device = key.device
+    key_cache, value_cache = kv_cache[0], kv_cache[1]
+    per_head_counts = survivors.sum(dim=0).to(torch.int32)
+
+    for head_idx in range(num_kv_heads):
+        survivor_indices = survivors[:, head_idx].nonzero(as_tuple=True)[0]
+        num_survivors = survivor_indices.shape[0]
+        if num_survivors == 0:
+            continue
+
+        dst_positions = torch.arange(
+            num_survivors, device=device, dtype=torch.long,
+        )
+        dst_block_ids = block_table[dst_positions // block_size]
+        dst_offsets = dst_positions % block_size
+
+        key_cache[dst_block_ids, dst_offsets, head_idx] = key[
+            survivor_indices, head_idx
+        ]
+        value_cache[dst_block_ids, dst_offsets, head_idx] = value[
+            survivor_indices, head_idx
+        ]
+
+    return per_head_counts
+
+
 def compact_kv_cache(
     kv_cache: torch.Tensor,
     survivors: torch.Tensor,
@@ -61,8 +121,8 @@ def compact_kv_cache(
 ) -> tuple[torch.Tensor, bool]:
     """Compact KV cache using vectorized gather/scatter.
 
-    For each head: gathers surviving KV pairs from their original
-    paged positions and scatters them to contiguous positions 0..N-1.
+    Fallback for chunked prefill where tokens are already in cache.
+    For non-chunked prefill, use ``write_survivors_to_cache`` instead.
 
     Args:
         kv_cache: ``(2, num_blocks, block_size, num_kv_heads, head_size)``.
