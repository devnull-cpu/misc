+    # --- 3. Time the full decoder layer (attn + MLP + norms + decisions) ---
+    from vllm.model_executor.models.qwen3_dms import Qwen3DMSDecoderLayer
+    orig_decoder_forward = Qwen3DMSDecoderLayer.forward
