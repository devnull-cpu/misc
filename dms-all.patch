+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Benchmark prefill (input) throughput: DMS on vs off.
+
+Usage:
+    python tests/v1/attention/bench_prefill.py dms_on
+    python tests/v1/attention/bench_prefill.py dms_off
+    python tests/v1/attention/bench_prefill.py all
+"""
+
+import os
+import sys
+import time
+
+os.environ["VLLM_ENABLE_V1_MULTIPROCESSING"] = "0"
+
+
+MODEL_PATH = os.path.normpath(os.path.join(
+    os.path.dirname(os.path.abspath(__file__)),
+    "..", "..", "..", "models", "Qwen3-8B-DMS-8x-4bit-NF4",
+))
+
+# Long prompt to stress prefill.
+LONG_PROMPT = (
+    "Please provide a comprehensive analysis of the following topics. "
+    "First, explain the history and development of quantum mechanics from "
+    "its origins in blackbody radiation through the Copenhagen interpretation "
+    "and modern quantum field theory. Include discussions of wave-particle "
+    "duality, the uncertainty principle, quantum entanglement, and Bell's "
+    "theorem. Then transition to discussing the mathematical foundations "
+    "including Hilbert spaces, operators, eigenvalues, and the Schrodinger "
+    "equation in both time-dependent and time-independent forms. "
+    "Next, cover the applications of quantum mechanics in modern technology "
+    "including semiconductors, lasers, MRI machines, and quantum computing. "
+    "Discuss the current state of quantum computing research, including "
+    "superconducting qubits, trapped ions, topological qubits, and photonic "
+    "quantum computing approaches. Cover error correction, fault tolerance, "
+    "and the threshold theorem. Finally, discuss philosophical implications "
+    "of quantum mechanics including the measurement problem, many-worlds "
+    "interpretation, decoherence, and the relationship between quantum "
+    "mechanics and consciousness. Compare and contrast the Copenhagen, "
+    "many-worlds, pilot wave, and objective collapse interpretations. "
+    "Be thorough and detailed in your analysis of each topic area."
+)
+
+
+def bench(dms_enabled: bool):
+    from vllm import LLM, SamplingParams
+
+    label = "DMS ON" if dms_enabled else "DMS OFF"
+    print(f"\n[{label}] Loading model...")
+
+    llm = LLM(
+        model=MODEL_PATH,
+        quantization="bitsandbytes",
+        load_format="bitsandbytes",
+        max_model_len=2048,
+        gpu_memory_utilization=0.7,
+        enforce_eager=True,
+    )
+
+    if not dms_enabled:
+        from vllm.v1.attention.backends.dms_flash_attn import DMSFlashAttentionImpl
+        for impl in DMSFlashAttentionImpl._all_instances:
+            impl._dms_config = None
+            impl._dms_state = None
+
+    sampling = SamplingParams(max_tokens=32, temperature=0.7, top_p=0.9)
+
+    # Warmup.
+    llm.generate(["Hello"], SamplingParams(max_tokens=4))
+
+    # Run with long prompt.
+    start = time.perf_counter()
+    outputs = llm.generate([LONG_PROMPT], sampling)
+    elapsed = time.perf_counter() - start
+
+    prompt_tokens = len(outputs[0].prompt_token_ids)
+    gen_tokens = len(outputs[0].outputs[0].token_ids)
+
+    # Estimate prefill vs decode time.
+    # With only 32 output tokens, most time is prefill.
+    input_tps = prompt_tokens / elapsed
+    output_tps = gen_tokens / elapsed
+
+    print(f"\n[{label}] Results:")
+    print(f"  Prompt tokens: {prompt_tokens}")
+    print(f"  Generated tokens: {gen_tokens}")
+    print(f"  Total time: {elapsed:.2f}s")
+    print(f"  Input throughput: {input_tps:.1f} tok/s")
+    print(f"  Output throughput: {output_tps:.1f} tok/s")
+    print()
+
+
+def run_all():
+    import subprocess
+    script = os.path.abspath(__file__)
+    for mode in ["dms_on", "dms_off"]:
+        print(f"\n{'#' * 50}")
+        print(f"# {mode}")
+        print(f"{'#' * 50}")
+        subprocess.run(
+            [sys.executable, script, mode],
+            env={**os.environ, "VLLM_ENABLE_V1_MULTIPROCESSING": "0"},
+        )
+
+
+if __name__ == "__main__":
+    mode = sys.argv[1] if len(sys.argv) > 1 else "all"
+    if mode == "dms_on":
+        bench(True)
+    elif mode == "dms_off":
+        bench(False)
+    elif mode == "all":
+        run_all()
+    else:
+        print(f"Unknown: {mode}. Use dms_on|dms_off|all")
