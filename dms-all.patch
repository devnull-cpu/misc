+    del llm
+    DMSFlashAttentionImpl._all_instances.clear()
+    gc.collect()
+    try:
+        import torch
+        torch.cuda.empty_cache()
+    except Exception:
+        pass
+
+
+def main():
+    mode = sys.argv[1] if len(sys.argv) > 1 else "all"
+
+    if mode == "all":
+        for ctx in [2048, 4096, 8192]:
+            bench(ctx)
+    else:
+        try:
+            ctx_len = int(mode)
+        except ValueError:
+            print(f"Usage: {sys.argv[0]} [2048|4096|8192|all]")
+            sys.exit(1)
