+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Unit tests for the Triton DMS paged decode kernel.
+
+Tests correctness against a naive PyTorch reference implementation.
+Runs on GPU only (requires CUDA + Triton).
+
+Run with: pytest tests/v1/attention/test_triton_dms_decode.py -v -s --noconftest
+"""
+
+import pytest
+import torch
+
+if not torch.cuda.is_available():
+    pytest.skip("CUDA GPU required", allow_module_level=True)
+
+from vllm.v1.attention.dms.triton_dms_decode import dms_paged_decode_attention
+
+
+def _reference_paged_decode(
+    query: torch.Tensor,
+    key_cache: torch.Tensor,
+    value_cache: torch.Tensor,
+    block_table: torch.Tensor,
+    per_head_seq_lens: torch.Tensor,
+    num_kv_heads: int,
+    num_q_heads: int,
+    head_size: int,
+    scale: float,
+) -> torch.Tensor:
+    """Naive PyTorch reference: loop over requests and heads."""
+    num_reqs = query.shape[0]
+    block_size = key_cache.shape[1]
+    q_per_kv = num_q_heads // num_kv_heads
+    output = torch.zeros_like(query)
+
+    for r in range(num_reqs):
+        for h in range(num_kv_heads):
+            seq_len = int(per_head_seq_lens[r * num_kv_heads + h].item())
+            if seq_len == 0:
+                continue
+
+            # Gather K/V for this head from paged blocks.
+            k_list = []
+            v_list = []
+            for pos in range(seq_len):
+                block_idx = pos // block_size
+                offset = pos % block_size
+                phys_block = int(block_table[r, block_idx].item())
+                k_list.append(key_cache[phys_block, offset, h, :])
+                v_list.append(value_cache[phys_block, offset, h, :])
+
+            k = torch.stack(k_list)  # (seq_len, head_size)
+            v = torch.stack(v_list)  # (seq_len, head_size)
+
+            # Compute attention for each query head in this GQA group.
+            for qh_offset in range(q_per_kv):
+                qh = h * q_per_kv + qh_offset
+                q_vec = query[r, qh, :].float()  # (head_size,)
+                scores = (q_vec @ k.float().T) * scale  # (seq_len,)
+                weights = torch.softmax(scores, dim=-1)  # (seq_len,)
+                out = weights @ v.float()  # (head_size,)
+                output[r, qh, :] = out.to(query.dtype)
+
+    return output
+
+
+def _make_paged_kv_cache(
+    num_reqs: int,
+    seq_lens: list[list[int]],
+    num_kv_heads: int,
+    head_size: int,
+    block_size: int,
+    dtype: torch.dtype = torch.bfloat16,
+    device: str = "cuda",
+):
+    """Create a paged KV cache with random data and return cache + block_table.
+
+    seq_lens: list of lists, seq_lens[r][h] = seq len for req r, head h.
+    """
+    max_seq = max(s for req_lens in seq_lens for s in req_lens)
+    max_blocks_per_req = (max_seq + block_size - 1) // block_size
+    total_blocks = num_reqs * max_blocks_per_req + 1  # +1 for safety
+
+    key_cache = torch.randn(
+        total_blocks, block_size, num_kv_heads, head_size,
+        dtype=dtype, device=device,
+    ) * 0.1
+    value_cache = torch.randn(
+        total_blocks, block_size, num_kv_heads, head_size,
+        dtype=dtype, device=device,
+    ) * 0.1
+
+    # Simple block allocation: req r gets blocks [r*max_blocks, (r+1)*max_blocks).
+    block_table = torch.zeros(
+        num_reqs, max_blocks_per_req, dtype=torch.int32, device=device,
+    )
+    for r in range(num_reqs):
+        for b in range(max_blocks_per_req):
+            block_table[r, b] = r * max_blocks_per_req + b
+
+    # Flatten per-head seq lens.
+    per_head_seq_lens = torch.tensor(
+        [s for req_lens in seq_lens for s in req_lens],
+        dtype=torch.int32, device=device,
+    )
+
+    return key_cache, value_cache, block_table, per_head_seq_lens
+
+
