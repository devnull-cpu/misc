+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Configuration for Dynamic Memory Sparsification (DMS)."""
+
+from dataclasses import dataclass
+
+
+@dataclass
+class DMSConfig:
+    """Configuration for DMS KV cache compression.
+
+    These parameters are read from the HuggingFace model config.json
+    for DMS-trained checkpoints.
+    """
+
+    dms_window_size: int = 512
+    """Delayed eviction window size. Tokens survive this many steps
+    after being marked for eviction before actual removal."""
+
+    dms_compression_ratio: int = 8
+    """Target compression ratio for the KV cache."""
+
+    decision_scale: float = 100.0
+    """Scale factor applied to the raw eviction logit."""
+
+    initial_decision_offset: float = 5.0
+    """Initial offset subtracted from the scaled logit.
+    Higher values mean less eviction at the start."""
+
+    dms_alpha_per: str = "head"
+    """Eviction granularity: 'head' for per-head (published results)
+    or 'layer' for per-layer (shared across heads)."""
+
+    @staticmethod
+    def from_hf_config(hf_config) -> "DMSConfig | None":
+        """Extract DMSConfig from a HuggingFace model config, if present.
+
+        Returns None if the config does not contain DMS parameters.
+        """
+        if not hasattr(hf_config, "dms_window_size"):
+            return None
+        return DMSConfig(
+            dms_window_size=getattr(hf_config, "dms_window_size", 512),
+            dms_compression_ratio=getattr(hf_config, "dms_cr", 8),
+            decision_scale=getattr(hf_config, "dms_alpha_scale", 100.0),
+            initial_decision_offset=getattr(
+                hf_config, "dms_initial_alpha_offset", 5.0
+            ),
+            dms_alpha_per=getattr(hf_config, "dms_alpha_per", "head"),
+        )
