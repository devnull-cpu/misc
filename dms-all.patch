+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Triton paged decode kernel for DMS per-head attention.
+
+Replaces the per-KV-head loop in DMSFlashAttentionImpl._forward_decode_per_head
+with a single fused kernel launch.
+
+Problem: vLLM's KV cache stores all heads in shared blocks
+    (num_blocks, block_size, num_kv_heads, head_size)
+but DMS needs per-head sequence lengths. The naive approach loops over
+KV heads, creating .contiguous() single-head copies and calling flash_attn
+for each — 8 calls per layer, 288 per decode step on Qwen3-8B.
+
+Solution: a Triton kernel where each program handles one (request, query_head)
+pair. It reads K/V from the paged cache at the specific KV head index, using
+that head's sequence length, and computes scaled dot-product attention with
+online softmax. All programs run in parallel in a single kernel launch.
+
+For Qwen3-8B: 288 flash_attn calls + .contiguous() copies -> 1 kernel launch
+with 32 * batch_size programs (or num_q_heads * batch_size in general).
+"""
+
+from __future__ import annotations
+
+import torch
+import triton
+import triton.language as tl
+
+
+@triton.jit
+def _dms_paged_decode_attention_kernel(
+    # Pointers
+    Q_ptr,              # (num_reqs, num_q_heads, head_dim)
+    K_cache_ptr,        # (num_blocks, block_size, num_kv_heads, head_dim)
+    V_cache_ptr,        # (num_blocks, block_size, num_kv_heads, head_dim)
+    Out_ptr,            # (num_reqs, num_q_heads, head_dim)
+    block_table_ptr,    # (num_reqs, max_num_blocks_per_req), int32
+    seq_lens_ptr,       # (num_reqs * num_kv_heads,), int32 — per-head
+    # Scalar
+    sm_scale,
+    # Q strides (element counts)
+    stride_qt, stride_qh, stride_qd,
+    # K cache strides
+    stride_kb, stride_ks, stride_kh, stride_kd,
+    # V cache strides
+    stride_vb, stride_vs, stride_vh, stride_vd,
+    # Output strides
+    stride_ot, stride_oh, stride_od,
+    # Block table strides
+    stride_bt, stride_bb,
+    # Constants
+    NUM_KV_HEADS: tl.constexpr,
+    Q_PER_KV: tl.constexpr,
+    HEAD_DIM: tl.constexpr,
+    BLOCK_SIZE: tl.constexpr,
+    MAX_NUM_BLOCKS: tl.constexpr,
+):
+    """Paged decode attention with per-head sequence lengths.
+
+    Grid: (num_reqs * num_q_heads,)
+    Each program computes attention for one query head of one request,
+    reading K/V from the paged cache at the corresponding KV head index.
+
+    The online softmax accumulates in float32 for numerical stability,
+    then casts back to the output dtype.
+    """
+    pid = tl.program_id(0)
+    num_q_heads = NUM_KV_HEADS * Q_PER_KV
+    req_idx = pid // num_q_heads
+    q_head_idx = pid % num_q_heads
+    kv_head_idx = q_head_idx // Q_PER_KV
+
+    # Per-head sequence length for this (request, kv_head).
+    seq_len = tl.load(seq_lens_ptr + req_idx * NUM_KV_HEADS + kv_head_idx)
+
+    # Load Q vector: (HEAD_DIM,), pre-scaled.
+    d_offs = tl.arange(0, HEAD_DIM)
+    q_base = Q_ptr + req_idx * stride_qt + q_head_idx * stride_qh
+    q_vec = tl.load(q_base + d_offs * stride_qd).to(tl.float32) * sm_scale
+
+    # Online softmax accumulators.
+    m_i = tl.full([], float("-inf"), dtype=tl.float32)
+    l_i = tl.zeros([], dtype=tl.float32)
+    acc = tl.zeros([HEAD_DIM], dtype=tl.float32)
+
+    # Slot offsets within a block (reused every iteration).
+    s_offs = tl.arange(0, BLOCK_SIZE)
+
+    # Iterate over page blocks.
+    # Using constexpr MAX_NUM_BLOCKS with early-exit mask to ensure
+    # Triton can compile the loop. Iterations past seq_len are skipped
+    # via masking (scores set to -inf, contributing nothing to output).
+    for block_idx in range(MAX_NUM_BLOCKS):
+        block_start = block_idx * BLOCK_SIZE
+
+        # Positions covered by this block.
+        pos = block_start + s_offs
+        active_mask = pos < seq_len
+
+        # If entire block is past seq_len, remaining blocks are too.
+        # We can't break, but masking makes inactive iterations free
+        # (no contribution to softmax). The cost is wasted K/V loads
+        # for blocks past seq_len, bounded by MAX_NUM_BLOCKS - actual.
+
+        # Load physical block ID from the (shared) block table.
+        phys_block = tl.load(
+            block_table_ptr + req_idx * stride_bt + block_idx * stride_bb
+        )
+
+        # Load K for this KV head from this physical block.
+        # K_cache layout: (num_blocks, block_size, num_kv_heads, head_dim)
+        # We want: K_cache[phys_block, 0:block_size, kv_head_idx, :]
+        k_base = (
+            K_cache_ptr
+            + phys_block * stride_kb
+            + kv_head_idx * stride_kh
+        )
+        k_ptrs = k_base + s_offs[:, None] * stride_ks + d_offs[None, :] * stride_kd
+        k_block = tl.load(k_ptrs, mask=active_mask[:, None], other=0.0)
+        # k_block: (BLOCK_SIZE, HEAD_DIM)
+
+        # QK^T: dot product of q_vec with each K vector.
+        # q_vec: (HEAD_DIM,), k_block: (BLOCK_SIZE, HEAD_DIM)
+        # Result: (BLOCK_SIZE,)
+        qk = tl.sum(q_vec[None, :] * k_block, axis=1)
+
+        # Mask positions beyond seq_len.
+        qk = tl.where(active_mask, qk, float("-inf"))
+
+        # Online softmax update.
+        m_ij = tl.max(qk, axis=0)  # scalar
+        m_new = tl.maximum(m_i, m_ij)
+
+        # Rescale previous accumulator.
+        # Guard against -inf - (-inf) = NaN.
+        alpha = tl.where(m_i > float("-inf"), tl.exp(m_i - m_new), 0.0)
+
+        # Softmax weights for this block.
+        p = tl.where(
+            m_new > float("-inf"),
+            tl.exp(qk - m_new),
+            0.0,
+        )
+        p = tl.where(active_mask, p, 0.0)  # (BLOCK_SIZE,)
+
+        l_i = l_i * alpha + tl.sum(p, axis=0)
+        acc = acc * alpha
+
+        # Load V for this KV head from this physical block.
+        v_base = (
+            V_cache_ptr
+            + phys_block * stride_vb
+            + kv_head_idx * stride_vh
+        )
+        v_ptrs = v_base + s_offs[:, None] * stride_vs + d_offs[None, :] * stride_vd
+        v_block = tl.load(v_ptrs, mask=active_mask[:, None], other=0.0)
+        # v_block: (BLOCK_SIZE, HEAD_DIM)
+
+        # Weighted sum: acc += p^T @ V
+        # p: (BLOCK_SIZE,), v_block: (BLOCK_SIZE, HEAD_DIM)
+        acc += tl.sum(p[:, None] * v_block, axis=0)
+
+        m_i = m_new
+
+    # Final normalization.
+    l_safe = tl.where(l_i > 0.0, l_i, 1.0)
+    acc = acc / l_safe
+
+    # Store output.
+    out_base = Out_ptr + req_idx * stride_ot + q_head_idx * stride_oh
+    tl.store(out_base + d_offs * stride_od, acc.to(Out_ptr.dtype.element_ty))
+
+
+def dms_paged_decode_attention(
+    query: torch.Tensor,
+    key_cache: torch.Tensor,
+    value_cache: torch.Tensor,
+    output: torch.Tensor,
+    block_table: torch.Tensor,
+    per_head_seq_lens: torch.Tensor,
+    num_kv_heads: int,
+    num_q_heads: int,
+    head_size: int,
+    scale: float,
+) -> torch.Tensor:
+    """Launch the Triton paged decode kernel for DMS per-head attention.
+
+    Args:
+        query: (num_reqs, num_q_heads, head_size) — one token per request.
+        key_cache: (num_blocks, block_size, num_kv_heads, head_size).
+        value_cache: same shape as key_cache.
+        output: (num_reqs, num_q_heads, head_size) or larger — written in-place.
+        block_table: (num_reqs, max_num_blocks_per_req), int32.
+            Shared across heads (vLLM allocates blocks for all heads together).
+        per_head_seq_lens: (num_reqs * num_kv_heads,), int32.
+            Layout: [req0_head0, req0_head1, ..., req0_headH, req1_head0, ...].
+        num_kv_heads: number of KV heads (e.g. 8 for Qwen3-8B).
+        num_q_heads: number of query heads (e.g. 32 for Qwen3-8B).
+        head_size: dimension per head (e.g. 128).
+        scale: softmax scale factor (typically 1/sqrt(head_size)).
+
+    Returns:
+        output tensor (written in-place).
+    """
+    num_reqs = query.shape[0]
+    if num_reqs == 0:
+        return output
+
+    if not hasattr(dms_paged_decode_attention, "_logged"):
+        dms_paged_decode_attention._logged = True
+        print(f"\n[DMS Triton decode] ACTIVE — num_reqs={num_reqs}, "
+              f"block_table={block_table.shape}, "
+              f"max_seq={int(per_head_seq_lens.max().item())}")
+
+    block_size = key_cache.shape[1]
+    q_per_kv = num_q_heads // num_kv_heads
+
+    # Compute the actual max blocks needed from per-head seq_lens,
+    # NOT block_table.shape[1] which is sized for the full max_model_len
+    # and would cause Triton to unroll thousands of iterations.
+    max_seq = int(per_head_seq_lens.max().item())
+    max_blocks_needed = (max_seq + block_size - 1) // block_size
+    # Round up to next power of 2 to limit the number of Triton
+    # recompilations as seq_len grows during generation.
+    max_blocks_needed = max(1, triton.next_power_of_2(max_blocks_needed))
+    # Clamp to block_table width (can't read past it).
+    max_blocks_needed = min(max_blocks_needed, block_table.shape[1])
+
+    # Round HEAD_DIM to next power of 2 for Triton constexpr.
+    head_dim_padded = triton.next_power_of_2(head_size)
+
+    grid = (num_reqs * num_q_heads,)
+
+    _dms_paged_decode_attention_kernel[grid](
+        query,
+        key_cache,
+        value_cache,
+        output,
+        block_table,
+        per_head_seq_lens,
+        scale,
+        # Q strides
+        query.stride(0), query.stride(1), query.stride(2),
+        # K cache strides
+        key_cache.stride(0), key_cache.stride(1),
+        key_cache.stride(2), key_cache.stride(3),
+        # V cache strides
+        value_cache.stride(0), value_cache.stride(1),
+        value_cache.stride(2), value_cache.stride(3),
+        # Output strides
+        output.stride(0), output.stride(1), output.stride(2),
+        # Block table strides
+        block_table.stride(0), block_table.stride(1),
+        # Constants
+        NUM_KV_HEADS=num_kv_heads,
+        Q_PER_KV=q_per_kv,
+        HEAD_DIM=head_dim_padded,
+        BLOCK_SIZE=block_size,
+        MAX_NUM_BLOCKS=max_blocks_needed,
+    )
+
+    return output
