+class TestPrefixCachingCoW:
+    """Verify DMS copy-on-write works with prefix caching enabled."""
+
+    def test_shared_prefix_two_requests(self, dms_llm):
+        """Two requests with identical prefix should both produce output.
+
+        The second request hits prefix cache, triggering CoW so that
+        DMS compaction on each request doesn't corrupt the other.
+        """
+        shared_prefix = (
+            "You are a helpful assistant. Please answer the following "
+            "question concisely and accurately. "
+        )
+        prompts = [
+            shared_prefix + "What is the capital of France?",
+            shared_prefix + "What is the capital of Germany?",
+        ]
+        params = SamplingParams(max_tokens=64, temperature=0.0)
+        outputs = dms_llm.generate(prompts, params)
+
+        assert len(outputs) == 2
+        for i, out in enumerate(outputs):
+            text = out.outputs[0].text
+            tokens = len(out.outputs[0].token_ids)
+            print(f"\n  Request {i}: {tokens} tokens — {text[:80]}...")
+            assert tokens > 0, f"Request {i} produced no output"
+
+    def test_repeated_prompt_produces_consistent_output(self, dms_llm):
+        """Same prompt twice — second should hit prefix cache fully.
+
+        With CoW, the second request gets private copies of all cached
+        blocks. Both should produce identical output (greedy decoding).
+        """
+        prompt = "What is 2 + 2? Give just the number."
+        params = SamplingParams(max_tokens=16, temperature=0.0)
+
+        out1 = dms_llm.generate([prompt], params)
+        out2 = dms_llm.generate([prompt], params)
+
+        text1 = out1[0].outputs[0].text
+        text2 = out2[0].outputs[0].text
+        print(f"\n  First:  {text1!r}")
+        print(f"  Second: {text2!r}")
+        assert text1 == text2, (
+            f"Same prompt produced different output:\n"
+            f"  First:  {text1!r}\n"
+            f"  Second: {text2!r}"
+        )
+
+    def test_shared_prefix_sequential_batches(self, dms_llm):
+        """Batch 1 with a prefix, then batch 2 reusing that prefix.
+
+        Verifies prefix cache survives DMS compaction of batch 1
+        (original shared blocks untouched thanks to CoW).
+        """
+        prefix = "The quick brown fox jumps over the lazy dog. "
+        params = SamplingParams(max_tokens=32, temperature=0.0)
+
+        # Batch 1: establish prefix in cache.
+        out1 = dms_llm.generate(
+            [prefix + "Continue this story:"], params
+        )
+        assert len(out1[0].outputs[0].token_ids) > 0
+
+        # Batch 2: reuse prefix — should hit cache, trigger CoW.
+        out2 = dms_llm.generate(
+            [prefix + "Now write a poem about this:"], params
