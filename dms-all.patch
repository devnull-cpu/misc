+    print(f"\nGeneration:")
+    print(f"  Prompt tokens: {prompt_tokens}")
+    print(f"  Generated tokens: {gen_tokens}")
+    print(f"  Total tokens: {total_tokens}")
+    print(f"  Time: {elapsed:.1f}s")
+    print(f"  Output throughput: {gen_tokens / elapsed:.1f} tok/s")
+
+    # Compression stats.
+    stats = _get_compression_stats()
+    if stats:
+        print(f"\nDMS Compression:")
+        print(f"  Avg compression ratio: {stats['avg_ratio']:.2f}x")
+        print(f"  Min ratio: {stats['min_ratio']:.2f}x")
+        print(f"  Max ratio: {stats['max_ratio']:.2f}x")
+        print(f"  Avg per-head spread: {stats['avg_spread']:.1f}")
+        print(f"  Max per-head spread: {stats['max_spread']}")
+        print(f"  Layers: {stats['num_layers']}")
+        print(f"\n  Last layer seq_lens:   {stats['sample_seq_lens']}")
+        print(f"  Last layer tokens_seen: {stats['sample_tokens_seen']}")
+
+        # Memory savings estimate.
+        if stats['sample_seq_lens'] and stats['sample_tokens_seen']:
+            avg_cache = sum(stats['sample_seq_lens']) / len(stats['sample_seq_lens'])
+            avg_seen = sum(stats['sample_tokens_seen']) / len(stats['sample_tokens_seen'])
+            if avg_seen > 0:
+                pct_saved = (1 - avg_cache / avg_seen) * 100
