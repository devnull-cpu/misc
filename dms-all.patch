@@ -0,0 +1,745 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Unit tests for DMS (Dynamic Memory Sparsification) core logic.
+
+Tests the model-agnostic DMS utilities: DMSState circular buffer and
+eviction tracking, prefill survivor computation, KV cache compaction,
+and DMSState initialization from prefill. All tests use CPU tensors —
+no GPU or model checkpoint required.
+"""
+
+import pytest
+import torch
+
+from vllm.config.dms import DMSConfig
+from vllm.v1.attention.dms.dms_prefill import (
+    compact_kv_cache,
+    compute_prefill_survivors,
+    initialize_dms_state_from_prefill,
+)
+from vllm.v1.attention.dms.dms_state import DMSState
+
+
+# ---------------------------------------------------------------------------
+# Helpers
+# ---------------------------------------------------------------------------
+
+def make_dms_state(
+    batch_size: int = 1,
+    num_kv_heads: int = 4,
+    window_size: int = 4,
+    max_seq_len: int = 64,
+    block_size: int = 16,
+) -> DMSState:
+    """Create a DMSState with small dimensions for testing."""
+    cfg = DMSConfig(dms_window_size=window_size)
+    return DMSState(
+        dms_config=cfg,
+        batch_size=batch_size,
+        num_kv_heads=num_kv_heads,
+        max_seq_len=max_seq_len,
+        block_size=block_size,
+        device=torch.device("cpu"),
+    )
+
+
+def make_kv_cache(
+    num_blocks: int = 4,
+    block_size: int = 16,
+    num_kv_heads: int = 4,
+    head_size: int = 8,
+) -> torch.Tensor:
+    """Create a KV cache with known values for verification.
+
+    cache[layer][block_id, offset, head, :] = block_id * 1000 + offset * 10 + head
+    so we can verify which entries moved where after compaction.
+    """
+    cache = torch.zeros(2, num_blocks, block_size, num_kv_heads, head_size)
+    for b in range(num_blocks):
+        for o in range(block_size):
+            for h in range(num_kv_heads):
+                val = float(b * 1000 + o * 10 + h)
+                cache[0, b, o, h, :] = val  # key
+                cache[1, b, o, h, :] = val  # value (same for easy checking)
+    return cache
+
+
+# ---------------------------------------------------------------------------
+# DMSState tests
+# ---------------------------------------------------------------------------
+
+
+class TestDMSStateInit:
+    def test_shapes(self):
+        state = make_dms_state(batch_size=2, num_kv_heads=4, window_size=8)
+        page_batch = 2 * 4
+        assert state.recent_info.shape == (page_batch, 8, 2)
+        assert state.cache_seq_lens.shape == (page_batch,)
+        assert state.circular_ptr.shape == (page_batch,)
+        assert state.free_slot_count.shape == (page_batch,)
+        assert state.tokens_seen.shape == (page_batch,)
+
+    def test_initial_values_are_zero(self):
+        state = make_dms_state()
+        assert (state.cache_seq_lens == 0).all()
+        assert (state.circular_ptr == 0).all()
+        assert (state.free_slot_count == 0).all()
+        assert (state.tokens_seen == 0).all()
+
+
+class TestDMSStateResetRequest:
+    def test_reset_clears_single_request(self):
+        state = make_dms_state(batch_size=2, num_kv_heads=4)
+        # Set some non-zero values for request 1.
+        start = 1 * 4
+        state.cache_seq_lens[start:start + 4] = 42
+        state.tokens_seen[start:start + 4] = 100
+
+        state.reset_request(1)
+
+        # Request 1 should be zeroed.
+        assert (state.cache_seq_lens[start:start + 4] == 0).all()
+        assert (state.tokens_seen[start:start + 4] == 0).all()
+        # Request 0 should be untouched (was already zero, but check).
+        assert (state.cache_seq_lens[:4] == 0).all()
+
+
+class TestDMSStateUpdateDecode:
+    def test_no_eviction_before_window_fills(self):
+        """Before window_size tokens are seen, no eviction should occur."""
+        state = make_dms_state(batch_size=1, num_kv_heads=2, window_size=4)
+        page_batch = 2
+
+        for step in range(3):  # 3 steps, window=4 → not full yet
+            decisions = torch.ones(1, 2)  # Mark everything for eviction
+            positions = torch.tensor([[step * 2, step * 2 + 1]])
+            evicted, grew = state.update_decode(decisions, positions)
+
+            # Window not full yet → no actual evictions.
+            assert (evicted == -1).all(), f"Step {step}: unexpected eviction"
+            assert grew.all(), f"Step {step}: should have grown"
+
+        # After 3 steps, cache_seq_lens should be 3 for each head.
+        assert (state.cache_seq_lens[:page_batch] == 3).all()
+
+    def test_eviction_after_window_fills(self):
+        """Once window_size tokens are seen, eviction should kick in."""
+        state = make_dms_state(batch_size=1, num_kv_heads=1, window_size=3)
+
+        # Fill the window: 3 tokens, all marked for eviction.
+        for step in range(3):
+            decisions = torch.ones(1, 1)
+            positions = torch.tensor([[step]])
+            state.update_decode(decisions, positions)
+
+        # cache_seq_lens should be 3 (grew each time, no eviction yet).
+        assert state.cache_seq_lens[0] == 3
+
+        # Next step: window is full, oldest entry (marked evict=1) should evict.
+        decisions = torch.ones(1, 1)
+        positions = torch.tensor([[3]])
+        evicted, grew = state.update_decode(decisions, positions)
+
+        assert evicted[0].item() == 0  # Slot 0 (oldest) was evicted.
+        assert not grew[0]  # Didn't grow (slot recycled).
+        assert state.cache_seq_lens[0] == 3  # Length unchanged.
+
+    def test_keep_decision_prevents_eviction(self):
+        """Tokens marked keep (0) should not be evicted when exiting window."""
+        state = make_dms_state(batch_size=1, num_kv_heads=1, window_size=2)
+
+        # Step 0: keep decision.
+        state.update_decode(
+            torch.tensor([[0]]),  # keep
+            torch.tensor([[0]]),
+        )
+        # Step 1: keep decision.
+        state.update_decode(
+            torch.tensor([[0]]),
+            torch.tensor([[1]]),
+        )
+
+        # Window full. Step 2: oldest (step 0) exits window.
+        # Step 0 was marked keep → should NOT evict.
+        evicted, grew = state.update_decode(
+            torch.tensor([[1]]),  # this step's decision (irrelevant to oldest)
+            torch.tensor([[2]]),
+        )
+        assert evicted[0].item() == -1  # No eviction.
+        assert grew[0]  # Cache grew.
+        assert state.cache_seq_lens[0] == 3
+
+    def test_free_slot_count_tracks_evictions(self):
+        """Free slot count should increase with each eviction."""
+        state = make_dms_state(batch_size=1, num_kv_heads=1, window_size=2)
+
+        # Fill window with evict decisions.
+        state.update_decode(torch.tensor([[1]]), torch.tensor([[0]]))
+        state.update_decode(torch.tensor([[1]]), torch.tensor([[1]]))
+        assert state.free_slot_count[0] == 0  # No evictions yet.
+
+        # Step 2: oldest (pos=0, evict=1) exits → evicted.
+        state.update_decode(torch.tensor([[1]]), torch.tensor([[2]]))
+        assert state.free_slot_count[0] == 1
+
+        # Step 3: oldest (pos=1, evict=1) exits → evicted.
+        state.update_decode(torch.tensor([[1]]), torch.tensor([[3]]))
+        assert state.free_slot_count[0] == 2
+
+
+    def test_circular_buffer_wraparound(self):
+        """Circular pointer wraps around window_size correctly."""
+        state = make_dms_state(batch_size=1, num_kv_heads=1, window_size=3)
+
+        # Push 5 entries into a window of size 3.
+        for step in range(5):
+            state.update_decode(
+                torch.tensor([[0]]),
+                torch.tensor([[step]]),
+            )
+
+        # ptr should be 5 % 3 = 2
+        assert state.circular_ptr[0] == 2
+        assert state.tokens_seen[0] == 5
+
+        # The circular buffer should contain the last 3 entries
+        # (positions 2, 3, 4) in the order they wrap.
+        # Buffer layout after 5 writes to window_size=3:
+        #   step 0 → buf[0], step 1 → buf[1], step 2 → buf[2],
+        #   step 3 → buf[0] (overwrite), step 4 → buf[1] (overwrite)
+        # So buf = [pos=3, pos=4, pos=2]
+        assert state.recent_info[0, 0, 0] == 3  # buf[0] = step 3
+        assert state.recent_info[0, 1, 0] == 4  # buf[1] = step 4
+        assert state.recent_info[0, 2, 0] == 2  # buf[2] = step 2
+
+    def test_mixed_decisions_across_heads(self):
+        """Different heads can evict/keep independently in same step."""
+        state = make_dms_state(batch_size=1, num_kv_heads=2, window_size=2)
+
+        # Step 0: head 0 evict, head 1 keep.
+        state.update_decode(
+            torch.tensor([[1, 0]]),
+            torch.tensor([[0, 0]]),
+        )
+        # Step 1: head 0 evict, head 1 keep.
+        state.update_decode(
+            torch.tensor([[1, 0]]),
+            torch.tensor([[1, 1]]),
+        )
+        # Step 2: window full. Head 0 oldest (evict=1) → evicted.
+        #         Head 1 oldest (evict=0) → kept.
+        evicted, grew = state.update_decode(
+            torch.tensor([[1, 0]]),
+            torch.tensor([[2, 2]]),
+        )
+
+        # Head 0 (page_batch idx 0): evicted slot 0, didn't grow.
+        assert evicted[0].item() == 0
+        assert not grew[0]
+        assert state.cache_seq_lens[0] == 2  # stayed at 2
+
+        # Head 1 (page_batch idx 1): no eviction, grew.
+        assert evicted[1].item() == -1
+        assert grew[1]
+        assert state.cache_seq_lens[1] == 3
+
+
+class TestDMSStateSlotRecycling:
+    def test_pop_free_slot_returns_evicted(self):
+        state = make_dms_state(batch_size=1, num_kv_heads=1, window_size=2)
+
+        # Fill and evict to get a free slot.
+        state.update_decode(torch.tensor([[1]]), torch.tensor([[10]]))
+        state.update_decode(torch.tensor([[1]]), torch.tensor([[11]]))
+        state.update_decode(torch.tensor([[1]]), torch.tensor([[12]]))
+        # Slot 10 should have been evicted.
+        assert state.free_slot_count[0] == 1
+
+        slot = state.pop_free_slot(torch.tensor([0]))
+        assert slot[0].item() == 10
+        assert state.free_slot_count[0] == 0
+
+    def test_pop_free_slot_empty_returns_neg1(self):
+        state = make_dms_state(batch_size=1, num_kv_heads=1, window_size=4)
+        slot = state.pop_free_slot(torch.tensor([0]))
+        assert slot[0].item() == -1
+
+    def test_get_decode_slot_mapping_reuses_free(self):
+        state = make_dms_state(batch_size=1, num_kv_heads=2, window_size=2)
+
+        # Head 0: evict. Head 1: keep.
+        state.update_decode(
+            torch.tensor([[1, 0]]),
+            torch.tensor([[0, 0]]),
+        )
+        state.update_decode(
+            torch.tensor([[1, 0]]),
+            torch.tensor([[1, 1]]),
+        )
+        # Head 0 window full next step → eviction. Head 1 → no eviction.
+        state.update_decode(
+            torch.tensor([[1, 0]]),
+            torch.tensor([[2, 2]]),
+        )
+        # Head 0: free_slot_count=1 (slot 0 evicted), cache_seq_lens=2.
+        # Head 1: free_slot_count=0, cache_seq_lens=3.
+        assert state.free_slot_count[0] == 1  # head 0
+        assert state.free_slot_count[1] == 0  # head 1
+
+        # get_decode_slot_mapping should reuse free slot for head 0,
+        # append for head 1.
+        slot_mapping = state.get_decode_slot_mapping(torch.tensor([0]))
+        # Head 0: popped free slot 0.
+        assert slot_mapping[0, 0].item() == 0
+        # Head 1: append at cache_seq_lens=3.
+        assert slot_mapping[0, 1].item() == 3
+
+
+# ---------------------------------------------------------------------------
+# Prefill survivor tests
+# ---------------------------------------------------------------------------
+
+
+class TestComputePrefillSurvivors:
+    def test_all_keep_all_survive(self):
+        """If all decisions are 0 (keep), all tokens survive."""
+        decisions = torch.zeros(10, 4)  # 10 tokens, 4 heads
+        survivors = compute_prefill_survivors(decisions, 10, window_size=3)
+        assert survivors.all()
+
+    def test_all_evict_window_survives(self):
+        """Even if all marked evict, trailing window tokens survive."""
+        decisions = torch.ones(10, 2)  # All evict.
+        survivors = compute_prefill_survivors(decisions, 10, window_size=3)
+
+        # Trailing 3 tokens (positions 7, 8, 9) always survive.
+        assert survivors[7:, :].all()
+        # Earlier tokens with shift-by-one: decision[t] applies to t-1.
+        # Token 0: shifted decision = decisions[1] = 1 → evicted (outside window).
+        assert not survivors[0, 0]
+
+    def test_shift_by_one_logic(self):
+        """Decision for token t is made by token t+1."""
+        # 5 tokens, 1 head, window=2.
+        # Decisions: [0, 1, 0, 0, 0]
+        # Shifted:   [1, 0, 0, 0, 0]  (decision[t] applies to t-1)
+        # Token 0: shifted=1, pos=0, outside window (5-2=3) → evicted
+        # Token 1: shifted=0 → survives
+        # Token 2: shifted=0 → survives
+        # Token 3: in window → survives
+        # Token 4: in window → survives
+        decisions = torch.tensor([[0], [1], [0], [0], [0]])
+        survivors = compute_prefill_survivors(decisions, 5, window_size=2)
+        assert not survivors[0, 0]  # evicted
+        assert survivors[1, 0]
+        assert survivors[2, 0]
+        assert survivors[3, 0]
+        assert survivors[4, 0]
+
+    def test_per_head_independence(self):
+        """Each head's survivors are computed independently."""
+        decisions = torch.zeros(6, 2)
+        # Head 0: evict token 0 (via decision at token 1).
+        decisions[1, 0] = 1
+        # Head 1: all keep.
+        survivors = compute_prefill_survivors(decisions, 6, window_size=2)
+
+        # Head 0: token 0 evicted (outside window, shifted decision=1).
+        assert not survivors[0, 0]
+        # Head 1: token 0 survives.
+        assert survivors[0, 1]
+
+    def test_single_token(self):
+        """Single token always survives (in window)."""
+        decisions = torch.ones(1, 2)
+        survivors = compute_prefill_survivors(decisions, 1, window_size=4)
+        assert survivors.all()
+
+    def test_seq_len_equals_window(self):
+        """When seq_len == window_size, all tokens are in window → all survive."""
+        decisions = torch.ones(4, 2)
+        survivors = compute_prefill_survivors(decisions, 4, window_size=4)
+        assert survivors.all()
+
+    def test_window_larger_than_seq_len(self):
+        """When window_size > seq_len, all tokens are in window → all survive."""
+        decisions = torch.ones(3, 2)
+        survivors = compute_prefill_survivors(decisions, 3, window_size=10)
+        assert survivors.all()
+
+
+# ---------------------------------------------------------------------------
+# KV cache compaction tests
+# ---------------------------------------------------------------------------
+
+
+class TestCompactKvCache:
+    def test_no_eviction_no_copy(self):
+        """When all tokens survive, seq_lens equal original and no copy needed."""
+        num_kv_heads = 2
+        seq_len = 4
+        block_size = 16
+        cache = make_kv_cache(
+            num_blocks=1, block_size=block_size,
+            num_kv_heads=num_kv_heads, head_size=8,
+        )
+        survivors = torch.ones(seq_len, num_kv_heads, dtype=torch.bool)
+        block_table = torch.tensor([0])
+
+        per_head_seq_lens, compacted = compact_kv_cache(
+            cache, survivors, seq_len, block_size, block_table,
+        )
+        assert (per_head_seq_lens == seq_len).all()
+
+    def test_eviction_compacts_correctly(self):
+        """Evicted tokens are removed, survivors are contiguous."""
+        num_kv_heads = 2
+        seq_len = 4
+        block_size = 16
+        cache = make_kv_cache(
+            num_blocks=1, block_size=block_size,
+            num_kv_heads=num_kv_heads, head_size=8,
+        )
+        block_table = torch.tensor([0])
+
+        # Head 0: evict token 1 (keep 0, 2, 3).
+        # Head 1: keep all.
+        survivors = torch.ones(seq_len, num_kv_heads, dtype=torch.bool)
+        survivors[1, 0] = False
+
+        original_key_cache = cache[0].clone()
+
+        per_head_seq_lens, _ = compact_kv_cache(
+            cache, survivors, seq_len, block_size, block_table,
+        )
+
+        assert per_head_seq_lens[0] == 3  # 4 - 1 evicted
+        assert per_head_seq_lens[1] == 4  # all kept
+
+        # Verify head 0 compaction: positions 0,2,3 → 0,1,2.
+        # Position 0 stayed at 0 (no move needed).
+        # Original position 2 → now at position 1.
+        key_cache = cache[0]
+        expected_src_pos2 = original_key_cache[0, 2, 0, :]  # block 0, offset 2, head 0
+        actual_dst_pos1 = key_cache[0, 1, 0, :]  # block 0, offset 1, head 0
+        assert torch.equal(expected_src_pos2, actual_dst_pos1)
+
+        # Original position 3 → now at position 2.
+        expected_src_pos3 = original_key_cache[0, 3, 0, :]
+        actual_dst_pos2 = key_cache[0, 2, 0, :]
+        assert torch.equal(expected_src_pos3, actual_dst_pos2)
+
+        # Head 1 should be untouched.
+        assert torch.equal(cache[0][:, :, 1, :], original_key_cache[:, :, 1, :])
+
+    def test_value_cache_compacted_too(self):
+        """Value cache must be compacted identically to key cache."""
+        num_kv_heads = 1
+        seq_len = 4
+        block_size = 16
+        cache = make_kv_cache(
+            num_blocks=1, block_size=block_size,
+            num_kv_heads=num_kv_heads, head_size=8,
+        )
+        block_table = torch.tensor([0])
+
+        # Evict token 1, keep 0, 2, 3.
+        survivors = torch.ones(seq_len, num_kv_heads, dtype=torch.bool)
+        survivors[1, 0] = False
+
+        original_value_cache = cache[1].clone()
+
+        compact_kv_cache(cache, survivors, seq_len, block_size, block_table)
+
+        # Value at original position 2 → compacted position 1.
+        assert torch.equal(
+            cache[1, 0, 1, 0, :],
+            original_value_cache[0, 2, 0, :],
+        )
+        # Value at original position 3 → compacted position 2.
+        assert torch.equal(
+            cache[1, 0, 2, 0, :],
+            original_value_cache[0, 3, 0, :],
+        )
+
+    def test_heavy_eviction_across_blocks(self):
+        """Many evictions across multiple blocks produce correct contiguous layout."""
+        num_kv_heads = 1
+        block_size = 4
+        seq_len = 12  # 3 blocks
+        cache = make_kv_cache(
+            num_blocks=3, block_size=block_size,
+            num_kv_heads=num_kv_heads, head_size=4,
+        )
+        block_table = torch.tensor([0, 1, 2])
+
+        # Keep only tokens 0, 4, 8 (one per block) → 3 survivors.
+        survivors = torch.zeros(seq_len, num_kv_heads, dtype=torch.bool)
+        survivors[0, 0] = True
+        survivors[4, 0] = True
+        survivors[8, 0] = True
+
+        original_cache = cache.clone()
+
+        per_head_seq_lens, _ = compact_kv_cache(
+            cache, survivors, seq_len, block_size, block_table,
+        )
+
+        assert per_head_seq_lens[0] == 3
+
+        # Token 0 stays at position 0 (block 0, offset 0).
+        assert torch.equal(
+            cache[0, 0, 0, 0, :],
+            original_cache[0, 0, 0, 0, :],
+        )
+        # Token 4 (block 1, offset 0) → position 1 (block 0, offset 1).
+        assert torch.equal(
+            cache[0, 0, 1, 0, :],
+            original_cache[0, 1, 0, 0, :],
+        )
+        # Token 8 (block 2, offset 0) → position 2 (block 0, offset 2).
+        assert torch.equal(
+            cache[0, 0, 2, 0, :],
+            original_cache[0, 2, 0, 0, :],
+        )
+
+    def test_cross_block_compaction(self):
+        """Compaction works when tokens span multiple blocks."""
+        num_kv_heads = 1
+        block_size = 2  # Tiny blocks to test cross-block.
+        seq_len = 4  # Spans 2 blocks.
+        cache = make_kv_cache(
+            num_blocks=2, block_size=block_size,
+            num_kv_heads=num_kv_heads, head_size=4,
+        )
+        block_table = torch.tensor([0, 1])
+
+        # Evict token 0, keep 1, 2, 3 → compacted to positions 0, 1, 2.
+        survivors = torch.ones(seq_len, num_kv_heads, dtype=torch.bool)
+        survivors[0, 0] = False
+
+        original_cache = cache.clone()
+
+        per_head_seq_lens, _ = compact_kv_cache(
+            cache, survivors, seq_len, block_size, block_table,
+        )
+
+        assert per_head_seq_lens[0] == 3
+
+        # Token 1 (block 0, offset 1) → position 0 (block 0, offset 0).
+        assert torch.equal(
+            cache[0, 0, 0, 0, :],  # dst: block 0, offset 0, head 0
+            original_cache[0, 0, 1, 0, :],  # src: block 0, offset 1, head 0
+        )
+
+        # Token 2 (block 1, offset 0) → position 1 (block 0, offset 1).
+        assert torch.equal(
+            cache[0, 0, 1, 0, :],  # dst: block 0, offset 1, head 0
+            original_cache[0, 1, 0, 0, :],  # src: block 1, offset 0, head 0
+        )
+
+
+# ---------------------------------------------------------------------------
+# Initialize DMSState from prefill
+# ---------------------------------------------------------------------------
+
+
+class TestInitializeDmsStateFromPrefill:
+    def test_seq_lens_set_correctly(self):
+        """Per-head seq_lens should match compacted survivor counts."""
+        state = make_dms_state(
+            batch_size=1, num_kv_heads=2, window_size=3,
+        )
+        # 6 tokens, head 0: 4 survivors, head 1: 6 survivors.
+        per_head_seq_lens = torch.tensor([4, 6], dtype=torch.int32)
+        decisions = torch.zeros(6, 2)
+        survivors = torch.ones(6, 2, dtype=torch.bool)
+        survivors[1, 0] = False
+        survivors[3, 0] = False
+
+        initialize_dms_state_from_prefill(
+            state, decisions, survivors, per_head_seq_lens,
+            req_idx=0, seq_len=6,
+        )
+
+        assert state.cache_seq_lens[0] == 4  # head 0
+        assert state.cache_seq_lens[1] == 6  # head 1
+
+    def test_tokens_seen_set_to_seq_len(self):
+        state = make_dms_state(
+            batch_size=1, num_kv_heads=1, window_size=3,
+        )
+        decisions = torch.zeros(10, 1)
+        survivors = torch.ones(10, 1, dtype=torch.bool)
+        per_head_seq_lens = torch.tensor([10], dtype=torch.int32)
+
+        initialize_dms_state_from_prefill(
+            state, decisions, survivors, per_head_seq_lens,
+            req_idx=0, seq_len=10,
+        )
+
+        assert state.tokens_seen[0] == 10
+
+    def test_circular_ptr_advances(self):
+        """Circular pointer should be at window_len % window_size."""
+        state = make_dms_state(
+            batch_size=1, num_kv_heads=1, window_size=4,
+        )
+        seq_len = 6  # window_start=2, window_len=4
+        decisions = torch.zeros(seq_len, 1)
+        survivors = torch.ones(seq_len, 1, dtype=torch.bool)
+        per_head_seq_lens = torch.tensor([seq_len], dtype=torch.int32)
+
+        initialize_dms_state_from_prefill(
+            state, decisions, survivors, per_head_seq_lens,
+            req_idx=0, seq_len=seq_len,
+        )
+
+        # window_len=4, window_size=4 → ptr = 4 % 4 = 0
+        assert state.circular_ptr[0] == 0
+
+    def test_multi_request_isolation(self):
+        """Requests should write to separate page_batch slices."""
+        state = make_dms_state(
+            batch_size=2, num_kv_heads=2, window_size=3,
+        )
+        decisions = torch.zeros(5, 2)
+        survivors = torch.ones(5, 2, dtype=torch.bool)
+        per_head_seq_lens = torch.tensor([5, 5], dtype=torch.int32)
+
+        # Init request 0
+        initialize_dms_state_from_prefill(
+            state, decisions, survivors, per_head_seq_lens,
+            req_idx=0, seq_len=5,
+        )
+        # Init request 1 with different values.
+        decisions2 = torch.zeros(3, 2)
+        survivors2 = torch.ones(3, 2, dtype=torch.bool)
+        per_head_seq_lens2 = torch.tensor([3, 3], dtype=torch.int32)
+
+        initialize_dms_state_from_prefill(
+            state, decisions2, survivors2, per_head_seq_lens2,
+            req_idx=1, seq_len=3,
+        )
+
+        # Request 0 heads: page_batch indices 0, 1.
+        assert state.cache_seq_lens[0] == 5
+        assert state.cache_seq_lens[1] == 5
+        assert state.tokens_seen[0] == 5
+        # Request 1 heads: page_batch indices 2, 3.
+        assert state.cache_seq_lens[2] == 3
+        assert state.cache_seq_lens[3] == 3
+        assert state.tokens_seen[2] == 3
+
+
+# ---------------------------------------------------------------------------
+# End-to-end: prefill compaction → decode cycle
+# ---------------------------------------------------------------------------
+
+
+class TestPrefillToDecodeCycle:
+    """Integration test: prefill with compaction, then decode steps."""
+
+    def test_steady_state_decode_with_eviction_and_reuse(self):
+        """Decode loop at steady state: continuous eviction + slot reuse."""
+        state = make_dms_state(
+            batch_size=1, num_kv_heads=1, window_size=3,
+        )
+
+        # Fill the window (3 steps), all marked evict.
+        for step in range(3):
+            state.update_decode(
+                torch.tensor([[1]]),
+                torch.tensor([[step]]),
+            )
+        assert state.cache_seq_lens[0] == 3
+
+        # Now run 10 more steps, all evict. Cache length should stay at 3
+        # because every step evicts the oldest and recycles its slot.
+        for step in range(10):
+            # Get slot to write to (should reuse evicted slot).
+            write_pos = state.get_decode_slot_mapping(torch.tensor([0]))
+            evicted, grew = state.update_decode(
+                torch.tensor([[1]]),
+                write_pos,
+            )
+            # Steady state: always evicting, never growing.
+            assert not grew[0], f"Step {step}: should not grow"
+            assert state.cache_seq_lens[0] == 3, (
+                f"Step {step}: length should stay at 3"
+            )
+
+    def test_prefill_compact_then_decode(self):
+        """Full cycle: prefill 8 tokens, compact, then 4 decode steps."""
+        num_kv_heads = 2
+        window_size = 3
+        seq_len = 8
+        block_size = 16
+
+        state = make_dms_state(
+            batch_size=1, num_kv_heads=num_kv_heads,
+            window_size=window_size, max_seq_len=64,
+            block_size=block_size,
+        )
+        cache = make_kv_cache(
+            num_blocks=4, block_size=block_size,
+            num_kv_heads=num_kv_heads, head_size=8,
+        )
+        block_table = torch.tensor([0, 1, 2, 3])
+
+        # Prefill decisions: evict some tokens for head 0, keep all for head 1.
+        decisions = torch.zeros(seq_len, num_kv_heads)
+        # Mark tokens 1, 3, 5 for eviction on head 0 (shift-by-one:
+        # decision[t] applies to t-1, so decisions[2]=1 evicts token 1, etc.).
+        decisions[2, 0] = 1  # Evicts token 1 on head 0
+        decisions[4, 0] = 1  # Evicts token 3 on head 0
+
+        survivors = compute_prefill_survivors(decisions, seq_len, window_size)
+
+        # Head 0: tokens 1, 3 evicted (outside window, shifted decision=1).
+        # Trailing window (positions 5, 6, 7) always survive.
+        assert not survivors[1, 0]  # token 1 evicted on head 0
+        assert not survivors[3, 0]  # token 3 evicted on head 0
+        # Head 1: all survive.
+        assert survivors[:, 1].all()
+
+        per_head_seq_lens, _ = compact_kv_cache(
+            cache, survivors, seq_len, block_size, block_table,
+        )
+
+        initialize_dms_state_from_prefill(
+            state, decisions, survivors, per_head_seq_lens,
+            req_idx=0, seq_len=seq_len,
+        )
+
+        head0_len = per_head_seq_lens[0].item()
+        head1_len = per_head_seq_lens[1].item()
+        assert head0_len == 6  # 8 - 2 evicted
+        assert head1_len == 8  # all kept
+
+        # Verify DMSState initialized correctly.
+        assert state.cache_seq_lens[0] == head0_len
+        assert state.cache_seq_lens[1] == head1_len
+        assert state.tokens_seen[0] == seq_len
+        assert state.tokens_seen[1] == seq_len
+
+        # --- Decode steps ---
+        for step in range(4):
+            # All keep decisions for simplicity.
+            decode_decisions = torch.zeros(1, num_kv_heads)
+            # Write positions: append at current seq_lens.
+            write_positions = state.get_decode_slot_mapping(torch.tensor([0]))
+            # write_positions shape: (1, num_kv_heads)
+
+            evicted, grew = state.update_decode(
+                decode_decisions, write_positions,
+            )
+
+            # No evictions (keep decisions + window may not be full yet
+            # from prefill init, depending on tokens_seen).
+            # Cache should grow.
+            assert grew.all() or state.tokens_seen[0] > seq_len + window_size
+
+        # After 4 decode steps with keep, seq_lens should have grown.
+        assert state.cache_seq_lens[0] >= head0_len
+        assert state.cache_seq_lens[1] >= head1_len
