+class TestMultiRequestBatching:
+    """Verify DMS works correctly with concurrent requests."""
+
+    def test_concurrent_requests_produce_output(self, dms_llm):
+        """Multiple concurrent requests should all produce coherent output."""
+        prompts = [
+            "What is the capital of France?",
+            "Explain photosynthesis briefly:",
+            "Write a haiku about the ocean:",
+            "What is 2 + 2?",
+        ]
+        params = SamplingParams(max_tokens=64, temperature=0.0)
+        outputs = dms_llm.generate(prompts, params)
+
+        assert len(outputs) == len(prompts)
+        for i, out in enumerate(outputs):
+            text = out.outputs[0].text
+            tokens = len(out.outputs[0].token_ids)
+            print(f"\n  Request {i}: {tokens} tokens — {text[:80]}...")
+            assert tokens > 0, f"Request {i} produced no output"
+
+    def test_sequential_batches_no_state_leak(self, dms_llm):
+        """After one batch finishes and a new batch starts, DMS state
+        should be clean — no stale state from previous requests.
+        """
+        params = SamplingParams(max_tokens=128, temperature=0.0)
+
+        # Batch 1: generate with one prompt.
+        out1 = dms_llm.generate(
+            ["Explain gravity in detail:"], params
+        )
+        text1 = out1[0].outputs[0].text
+        assert len(text1) > 0
+
+        # Batch 2: generate with different prompts — these reuse
+        # the same request slots. If DMS state wasn't reset,
+        # the old circular buffer / seq_lens would corrupt output.
+        out2 = dms_llm.generate(
+            ["What is machine learning?", "Describe the water cycle:"],
+            params,
+        )
+        for i, out in enumerate(out2):
+            text = out.outputs[0].text
+            tokens = len(out.outputs[0].token_ids)
+            print(f"\n  Batch 2 request {i}: {tokens} tokens — {text[:80]}...")
+            assert tokens > 0, f"Batch 2 request {i} produced no output"
+
+    def test_mixed_lengths_concurrent(self, dms_llm):
+        """Requests with different output lengths running concurrently.
+        Short requests finish first; their slots get cleaned up while
+        longer requests continue.
+        """
+        outputs = dms_llm.generate(
+            [
+                "Say hello.",
+                "Write a detailed essay about climate change, covering "
+                "causes, effects, and solutions:",
+            ],
+            [
+                SamplingParams(max_tokens=8, temperature=0.0),
+                SamplingParams(max_tokens=256, temperature=0.0),
+            ],
+        )
+
+        short_tokens = len(outputs[0].outputs[0].token_ids)
+        long_tokens = len(outputs[1].outputs[0].token_ids)
+        print(f"\n  Short request: {short_tokens} tokens")
+        print(f"  Long request: {long_tokens} tokens")
+        assert short_tokens > 0
+        assert long_tokens > short_tokens, (
+            f"Long request ({long_tokens}) should have more tokens "
+            f"than short ({short_tokens})"
+        )
+
+        # Verify DMS state is clean after both finish.
+        stats = _get_dms_stats()
+        assert stats["active"]
+
+    def test_many_requests_throughput(self, dms_llm):
+        """Batch of 8 requests to stress-test concurrent DMS state management."""
+        prompts = [
+            f"Question {i}: What is {i} times {i+1}? Answer:"
+            for i in range(8)
+        ]
+        params = SamplingParams(max_tokens=32, temperature=0.0)
+        outputs = dms_llm.generate(prompts, params)
+
+        assert len(outputs) == 8
+        total_tokens = sum(len(o.outputs[0].token_ids) for o in outputs)
+        print(f"\n  8 requests, total output tokens: {total_tokens}")
+        for i, out in enumerate(outputs):
+            text = out.outputs[0].text
+            tokens = len(out.outputs[0].token_ids)
+            print(f"\n  Request {i}: {tokens} tokens — {text[:80]}...")
+            assert tokens > 0, f"Request {i} produced no output"
