+        result = orig_decoder_forward(self, *args, **kwargs)
+        TIMER.stop("3_decoder_layer_total")
+        return result
+
+    Qwen3DMSDecoderLayer.forward = timed_decoder_forward
+
+    # --- 4. Time just the DMS attention (Q proj + decisions + attn) ---
+    from vllm.model_executor.models.qwen3_dms import Qwen3DMSAttention
+    orig_attn_forward = Qwen3DMSAttention.forward
+
+    def timed_attn_forward(self, *args, **kwargs):
+        TIMER.start("4_qwen3_dms_attn")
+        result = orig_attn_forward(self, *args, **kwargs)
+        TIMER.stop("4_qwen3_dms_attn")
+        return result
+
+    Qwen3DMSAttention.forward = timed_attn_forward
+
+    print("[PROFILE] Timing patches installed (4 sections)")
+
+
+def run_profiled():
+    from vllm import LLM, SamplingParams
+
+    model_path = os.path.normpath(os.path.join(
+        os.path.dirname(os.path.abspath(__file__)),
+        "..", "..", "..", "models", "Qwen3-8B-DMS-8x-4bit-NF4",
+    ))
+
+    print("Loading model...")
+    llm = LLM(
+        model=model_path,
+        quantization="bitsandbytes",
+        load_format="bitsandbytes",
+        max_model_len=2048,
+        gpu_memory_utilization=0.85,
+        enforce_eager=True,
+    )
+
+    patch_timing()
+
+    sampling = SamplingParams(max_tokens=128, temperature=0.7, top_p=0.9)
+    prompt = "Explain the theory of general relativity in detail, covering"
+
+    # Warmup.
+    llm.generate(["Hello"], SamplingParams(max_tokens=8))
+    TIMER.totals.clear()
+    TIMER.counts.clear()
+
+    print(f"Generating {sampling.max_tokens} tokens...")
+    wall_start = time.perf_counter()
+    outputs = llm.generate([prompt], sampling)
+    wall_elapsed = time.perf_counter() - wall_start
+
+    gen_tokens = len(outputs[0].outputs[0].token_ids)
+    print(f"\nWall time: {wall_elapsed:.1f}s for {gen_tokens} tokens "
+          f"= {gen_tokens / wall_elapsed:.1f} tok/s")
+
+    TIMER.report(gen_tokens)
+
+    # Derived breakdown.
+    decoder_total = TIMER.totals.get("3_decoder_layer_total", 0)
+    attn_total = TIMER.totals.get("4_qwen3_dms_attn", 0)
+    dms_forward = TIMER.totals.get("2_dms_forward_total", 0)
+    cache_update = TIMER.totals.get("1_cache_update", 0)
+    wall_ms = wall_elapsed * 1000
+
+    print("=" * 70)
+    print("DERIVED BREAKDOWN (per token)")
+    print("=" * 70)
+    triton_decode = dms_forward - cache_update
+    decision_extract = attn_total - dms_forward
+    mlp_norms = decoder_total - attn_total
+    outside_layers = wall_ms - decoder_total
+
+    for label, ms in [
+        ("Triton decode kernel", triton_decode),
+        ("Fused cache update", cache_update),
+        ("Decision extraction (Q proj)", decision_extract),
+        ("MLP + norms", mlp_norms),
+        ("Outside decoder layers (scheduler etc)", outside_layers),
+    ]:
+        per_tok = ms / gen_tokens if gen_tokens > 0 else 0
+        pct = ms / wall_ms * 100 if wall_ms > 0 else 0
+        print(f"  {label:45s}: {ms:8.0f} ms ({per_tok:6.2f} ms/tok, {pct:5.1f}%)")
+
+    print(f"  {'WALL TOTAL':45s}: {wall_ms:8.0f} ms")
+    print()
+
+
+if __name__ == "__main__":
+    run_profiled()
