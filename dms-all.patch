+    def cow_shared_blocks_for_dms(
+        self, request_id: str
+    ) -> list[tuple[int, int]]:
+        """Replace shared blocks (ref_cnt > 1) with private copies for DMS.
+
+        DMS compacts KV cache in-place. Shared blocks (from prefix caching)
+        must be copied before compaction to avoid corrupting other requests.
+
+        Returns:
+            List of (old_block_id, new_block_id) pairs. The caller must
+            arrange GPU-side data copies before forward() runs.
